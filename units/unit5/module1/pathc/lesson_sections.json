        {
          "type": "dialogue",
          "text": "See this symbol: 1/4? That's how we write one out of four equal parts. The bottom number tells us how many equal parts we made. The top number tells us how many parts we selected."
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar",
