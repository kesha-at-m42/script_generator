                        "intervals": "1/4"
                      },
                      {
                        "tangible_id": "vocab_equal_parts",
                        "tangible_type": "vocab_card",
                        "description": "Vocab card: Equal Parts.",
                        "label": "Equal Parts"
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar",
              "tangible_type": "NumLine",
              "description": "Bar partitioned into 4 parts. Paint tool active.",
