[
  {
    "id": "s_intro",
    "type": "transition",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar",
          "tangible_type": "NumLine",
          "params": {
            "visual": "bar",
            "intervals": "1/2",
            "description": "Whole bar appears. Bar visual, interval lines at halves pre-set."
          }
        },
        {
          "type": "dialogue",
          "text": "Now that you've spotted equal parts, let's learn exactly how to make equal parts and name them."
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar",
              "tangible_type": "NumLine",
              "description": "Whole bar. Bar visual with halves intervals.",
              "visual": "bar",
              "intervals": "1/2"
            }
          ]
        }
      ],
      [
        {
          "type": "scene",
          "method": "update",
          "tangible_id": "bar",
          "params": {
            "intervals": null,
            "lcm": 6,
            "description": "Bar updates to empty whole bar. No intervals shown."
          }
        },
        {
          "type": "dialogue",
          "text": "Before we divide it, let's think about this for a second: This bar is our whole. It's like one chocolate bar. Everything we do next is a piece of THIS whole, not a different one."
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar",
              "tangible_type": "NumLine",
              "description": "Empty whole bar. No cuts.",
              "visual": "bar"
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_1_erase_mechanic",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar",
          "tangible_type": "NumLine",
          "params": {
            "visual": "bar",
            "lcm": 8,
            "description": "Empty whole bar appears."
          }
        },
        {
          "type": "dialogue",
          "text": "Let's divide it into equal parts. Watch first."
        },
        {
          "type": "scene",
          "method": "animate",
          "tangible_id": "bar",
          "params": {
            "event": "demo_place_cut",
            "status": "confirmed",
            "description": "Guide places a cut at the midpoint of the bar."
          }
        },
        {
          "type": "dialogue",
          "text": "Oh, and here's something helpful: if you make a cut you don't like, like placing a cut here..."
        },
        {
          "type": "scene",
          "method": "animate",
          "tangible_id": "bar",
          "params": {
            "event": "demo_bad_cut",
            "status": "proposed",
            "description": "Guide places an off-center cut to illustrate an unwanted cut."
          }
        },
        {
          "type": "dialogue",
          "text": "You can hover over the line and click with the eraser. Watch this!"
        },
        {
          "type": "scene",
          "method": "animate",
          "tangible_id": "bar",
          "params": {
            "event": "demo_erase_cut",
            "status": "confirmed",
            "description": "Guide erases the off-center cut using the eraser, restoring the midpoint cut only."
          }
