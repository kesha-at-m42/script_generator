        "remediations": [
          {
            "@type": "Remediation",
            "id": "light",
            "step": {
              "@type": "Step",
              "dialogue": "Not quite. Remember that eighths means eight equal spaces.",
              "audio_dir": "module_4/exit_check_7899881102066974151"
            }
          },
          {
            "@type": "Remediation",
            "id": "medium",
            "step": {
              "@type": "Step",
              "dialogue": "Here's a hint: [event:693c364d3f9298c7] The name eighths tells us we need eight intervals.",
              "audio_dir": "module_4/exit_check_7287308806670893899"
            }
          },
          {
            "@type": "Remediation",
            "id": "heavy",
            "step": {
              "@type": "Step",
              "dialogue": "[event:restore_snapshot_prompt_start]Watch me as I do it: This has 2 spaces [event:695ed032ccbaa76d] (halves), this has [event:695ed0bf8c31722e] 4 (fourths), this has 8 [event:695ed0e5220c7777] (eighths). We [event:697bb2783cbf7f7b]need the one with 8.",
              "audio_dir": "module_4/exit_check_9086030329121323311"
            }
          }
        ],
        "on_correct": {
          "@type": "Step",
          "dialogue": "Correct. You understand that eighths[event:697bafc2e8b4465e] means we need eight equal intervals.",
          "audio_dir": "module_4/exit_check_7734270796918951071"
        }
      }
    },
    {
      "@type": "Step",
      "dialogue": "You're getting stronger in understanding how many equal intervals to make! Nice work today! Let's practice more to help grow your skill and make understanding fractions feel automatic.",
