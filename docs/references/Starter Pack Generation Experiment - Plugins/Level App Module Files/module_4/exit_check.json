    {
      "@type": "Step",
      "dialogue": "[event:show_lines]Here are three different number lines. Can you find which one shows thirds, or three equal spaces between 0 and 1?",
      "audio_dir": "module_4/exit_check_4119753442125481489",
      "workspace": {
        "@type": "WorkspaceData",
        "tangibles": [
          {
            "@type": "NumLine",
            "ticks": "1/2",
            "labels": [
              "0",
              "1"
            ]
          },
          {
            "@type": "NumLine",
            "ticks": "1/3",
            "labels": [
              "0",
              "1"
            ]
          },
          {
            "@type": "NumLine",
            "ticks": "1/4",
            "labels": [
              "0",
              "1"
            ]
          }
        ]
      },
      "prompt": {
        "@type": "Prompt",
        "text": "Select the line that shows thirds.",
        "tool": {
          "@type": "Select",
          "is_single": true
        },
        "validator": {
          "@type": "SelectionValidator",
          "answer": 1
        },
        "remediations": [
          {
            "@type": "Remediation",
            "id": "light",
            "step": {
              "@type": "Step",
              "dialogue": "Look again. Keep in mind that we count the equal intervals in each line.",
              "audio_dir": "module_4/exit_check_3486601066759697626"
            }
          },
          {
            "@type": "Remediation",
            "id": "medium",
            "step": {
              "@type": "Step",
              "dialogue": "Thirds means [event:693c347eef725b9a] three equal parts, or intervals. Which line has three intervals?",
              "audio_dir": "module_4/exit_check_6499408866580350276"
            }
          },
          {
            "@type": "Remediation",
            "id": "heavy",
            "step": {
              "@type": "Step",
              "dialogue": "Count with me as I show you this one: [event:69174a98db38e1ae] The top line has [event:69174ac87e1759a6] 1, 2 intervals. That's halves. The middle has [event:69174b1db1552534] 1, 2, 3 intervals. That's thirds. And the bottom has [event:69174b3ccea4d64e] 1, 2, 3, 4. That's fourths.",
              "audio_dir": "module_4/exit_check_5769104077118097351"
            }
          }
        ],
        "on_correct": {
          "@type": "Step",
          "dialogue": "Yes! [event:697baad2518b3838]Three equal intervals make thirds.",
          "audio_dir": "module_4/exit_check_1150444987110066584"
        }
      }
    },
    {
      "@type": "Step",
      "dialogue": "[event:show_lines]Here's another number line. Does this line correctly show 4 equal parts?",
      "audio_dir": "module_4/exit_check_7362303545611873293",
      "workspace": {
        "@type": "WorkspaceData",
        "tangibles": [
          {
            "@type": "NumLine",
            "ticks": [
              "0",
              "2/6",
              "3/6",
              "5/6",
              "1"
            ],
            "labels": false
          }
        ]
      },
      "prompt": {
        "@type": "Prompt",
        "text": "Is this line showing 4 equal parts correctly?",
        "validator": {
          "@type": "MultipleChoiceValidator",
          "answer": [
            1
          ]
        },
        "choices": {
          "@type": "WorkspaceChoices",
          "allow_multiple": false,
          "options": [
            "Yes, it works",
            "No, the 4 parts are not equal",
            "No, there are 5 parts"
          ]
        },
        "remediations": [
          {
            "@type": "Remediation",
            "id": "light",
            "step": {
              "@type": "Step",
              "dialogue": "Not quite. Did you compare the sizes of the spaces between marks?",
              "audio_dir": "module_4/exit_check_1478849365538584714"
            }
          },
          {
            "@type": "Remediation",
            "id": "medium",
            "step": {
              "@type": "Step",
              "dialogue": "For fourths, each space [event:693c35d215737327] must be exactly the same size. ",
              "audio_dir": "module_4/exit_check_8335936185613365008"
            }
          },
          {
            "@type": "Remediation",
            "id": "heavy",
            "step": {
              "@type": "Step",
              "dialogue": "I'll help out: [event:693c360b6600cfe5] this space is bigger than this one. For fourths, all four spaces must be equal.",
              "audio_dir": "module_4/exit_check_2643811486859278870"
            }
          }
        ],
        "on_correct": {
          "@type": "Step",
          "dialogue": "Right. You noticed the [event:697bac864966581b]spaces aren't equal. Fourths need four equal intervals.",
          "audio_dir": "module_4/exit_check_4576677596564639020"
        }
      }
    },
    {
      "@type": "Step",
      "dialogue": "[event:show_lines]Next, take a look at these three lines. Which one would you use to show eighths?",
      "audio_dir": "module_4/exit_check_3401038321042373617",
      "workspace": {
        "@type": "WorkspaceData",
        "tangibles": [
          {
            "@type": "NumLine",
            "ticks": "1/2",
            "labels": [
              "0",
              "1"
            ]
          },
          {
            "@type": "NumLine",
