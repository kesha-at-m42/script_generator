        "@type": "SequenceMetadata",
        "problem_id": 6.0,
        "goal_id": 3.0,
        "goal_text": "The student can identify the fraction represented by a bar.",
        "verb": "IDENTIFY",
        "variables_covered": {
          "fractions": [
            "1/4"
          ]
        },
        "mastery_tier": "BASELINE",
        "mastery_component": "CONCEPTUAL",
        "mastery_verbs": [
          "IDENTIFY"
        ]
      },
      "steps": [
        {
          "@type": "Step",
          "dialogue": "Here's a bar with four equal parts and one part shaded. What [vocab]fraction[/vocab] does this bar show?",
          "audio_dir": "module_3/pool_3_5148684934937648581",
          "workspace": {
            "@type": "WorkspaceData",
            "tangibles": [
              {
                "@type": "NumLine",
                "visual": "bar",
                "intervals_is_shaded": [
                  0
                ],
                "intervals": "1/4"
              }
            ]
          },
          "prompt": {
            "@type": "Prompt",
            "text": "Select the fraction shown by the bar.",
            "validator": {
              "@type": "MultipleChoiceValidator",
              "answer": [
                0
              ]
            },
            "choices": {
              "@type": "WorkspaceChoices",
              "allow_multiple": false,
              "options": [
                "[fraction numerator=1 denominator=4][/fraction]",
                "[fraction numerator=4 denominator=1][/fraction]",
                "[fraction numerator=4 denominator=4][/fraction]"
              ]
            },
            "remediations": [
              {
                "@type": "Remediation",
                "id": "light",
                "step": {
                  "@type": "Step",
                  "dialogue": "Not quite. Look at how many parts are shaded and how many parts there are in total.",
                  "audio_dir": "module_3/pool_3_5650892829489671401"
                }
              },
              {
                "@type": "Remediation",
                "id": "medium",
                "step": {
                  "@type": "Step",
                  "metadata": {
                    "events": [
                      {
                        "name": "A_compare_shaded",
                        "description": "Compare the shaded parts of the first or the top bar with equal parts"
                      },
                      {
                        "name": "A_compare",
                        "description": "Compare all the parts of the first or the top bar with equal parts"
                      }
                    ]
                  },
                  "dialogue": "Let's think about this together. [event:A_compare_shaded]The shaded part shows us the top number, and [event:A_compare]all the equal parts tell us the [vocab]bottom number[/vocab].",
                  "audio_dir": "module_3/pool_3_6954624495079348571"
                }
              },
              {
                "@type": "Remediation",
                "id": "heavy",
                "step": {
                  "@type": "Step",
                  "metadata": {
                    "events": [
                      {
                        "name": "A_count_shaded",
                        "description": "Count and label the shaded parts"
                      },
                      {
                        "name": "A_count",
                        "description": "Count and label the parts of the first or the top bar"
                      }
                    ]
                  },
                  "dialogue": "Let me show you how to find this. [event:A_count_shaded]We have one part shaded - that's our top number. [event:A_count]Now let's count all the equal parts: 1, 2, 3, 4. That's our bottom number. So we have 1 out of 4 equal parts, which is one-fourth or [fraction numerator=1 denominator=4]one fourth[/fraction]. That's how we read fractions from a bar model.",
                  "audio_dir": "module_3/pool_3_9101714862136016023"
                }
              }
            ],
            "on_correct": {
              "@type": "Step",
              "dialogue": "That's right. One out of four equal parts is one-fourth.",
              "audio_dir": "module_3/pool_3_269314950431270965"
            }
          }
        }
      ]
    },
