                      {
                        "name": "selected_compare",
                        "description": "Compare parts of the selected bar"
                      }
                    ]
                  },
                  "dialogue": "Let's think about this together. One-half means 1 out of 2 equal parts. [event:selected_compare_shaded] Check the bar you selected - does it show 1 shaded part? Are there exactly 2 equal parts total?",
