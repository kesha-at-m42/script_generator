    {
      "@type": "Step",
      "dialogue": "Look at this bar [event:68faa9f36b2e1cb5] with one piece shaded. Select the fraction label that matches what you see.",
      "audio_dir": "module_2/exit_check_eacn3n",
      "workspace": {
        "@type": "WorkspaceData",
        "tangibles": [
          {
            "@type": "FracShape",
            "is_visible": false,
            "fractions": "1/4",
            "shaded": [
              0
            ]
          }
        ]
      },
      "prompt": {
        "@type": "Prompt",
        "text": "Click on the fraction that matches this bar.",
        "validator": {
          "@type": "MultipleChoiceValidator",
          "answer": [
            2
          ]
        },
        "choices": {
          "@type": "WorkspaceChoices",
          "allow_multiple": false,
          "options": [
            "[fraction numerator=1 denominator=2]1/2[/fraction]",
            "[fraction numerator=1 denominator=3]1/3[/fraction]",
            "[fraction numerator=1 denominator=4]1/4[/fraction]"
          ]
        },
        "remediations": [
          {
            "@type": "Remediation",
            "id": "light",
            "step": {
              "@type": "Step",
              "dialogue": "Remember to count the total equal parts.",
              "audio_dir": "module_2/exit_check_pi99gb"
            }
          },
          {
            "@type": "Remediation",
            "id": "medium",
            "step": {
              "@type": "Step",
              "dialogue": "This might help: watch as we count each part[event:recognition_task_md]  - one, two, three, four parts total. ",
              "audio_dir": "module_2/exit_check_ixnc64"
            }
          },
          {
            "@type": "Remediation",
            "id": "heavy",
            "step": {
              "@type": "Step",
              "dialogue": "[event:68faa8ca16584a50] This can be diffucult to understand at first. Stay with it! You're building a new way of thinking.",
              "audio_dir": "module_2/exit_check_45i4aw"
            }
          }
        ],
        "on_correct": {
          "@type": "Step",
          "dialogue": "Yes. You saw it right away. One part [event:68faa93e9cd2e155] out of four equals one-fourth.",
          "audio_dir": "module_2/exit_check_4643612036109625081"
        }
      }
    },
    {
      "@type": "Step",
      "dialogue": "Let's create one-sixth. Click to shade one-sixth.",
      "audio_dir": "module_2/exit_check_9u8711",
      "workspace": {
        "@type": "WorkspaceData",
        "tangibles": [
          {
            "@type": "FracShape",
            "fractions": "1/6"
          }
        ]
      },
      "prompt": {
        "@type": "Prompt",
        "text": "Click on one part to make one sixth.",
        "tool": {
          "@type": "Paint"
        },
        "validator": {
          "@type": "EqualShadedValidator",
          "answer": "1/6"
        },
        "remediations": [
          {
            "@type": "Remediation",
            "id": "light",
            "step": {
              "@type": "Step",
              "dialogue": "Remember, unit fractions have exactly one part shaded.",
              "audio_dir": "module_2/exit_check_henerx"
            }
          },
          {
            "@type": "Remediation",
            "id": "medium",
            "step": {
              "@type": "Step",
              "dialogue": "Try shading just one [event:construction_task_md] of the six parts.",
              "audio_dir": "module_2/exit_check_05iazh"
            }
          },
          {
            "@type": "Remediation",
            "id": "heavy",
            "step": {
              "@type": "Step",
              "dialogue": "Let me show you: 'One-sixth' means shade 1 part out of 6. Watch me shade one [event:construction_task_hv]. ",
              "audio_dir": "module_2/exit_check_trbzth"
            }
          }
        ],
        "on_correct": {
          "@type": "Step",
          "dialogue": "Yes. You made one-sixth [event:68faaacc92baa295] - exactly one part shaded.",
          "audio_dir": "module_2/exit_check_3680582519785764733"
        }
      }
    },
    {
      "@type": "Step",
      "dialogue": "This is new. It takes [vocab]practice[/vocab]. [event:68faab4a6ff92a2f] Which one of these is a unit fraction? Remember what we have learned so far. Click the [vocab]unit fraction[/vocab].",
      "audio_dir": "module_2/exit_check_jr7k9b",
      "workspace": {
        "@type": "WorkspaceData",
        "tangibles": [
          {
            "@type": "FracShape",
            "is_visible": false,
            "fractions": "1/3",
            "shaded": [
              0
            ]
          },
          {
            "@type": "FracShape",
            "is_visible": false,
            "fractions": "1/3",
            "shaded": [
              0,
              1
            ]
          }
        ]
