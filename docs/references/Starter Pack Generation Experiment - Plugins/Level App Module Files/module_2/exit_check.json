      "prompt": {
        "@type": "Prompt",
        "text": "Click on the bar that shows a unit fraction.",
        "tool": {
          "@type": "Select"
        },
        "validator": {
          "@type": "SelectionValidator",
          "answer": 0
        },
        "remediations": [
          {
            "@type": "Remediation",
            "id": "light",
            "step": {
              "@type": "Step",
              "dialogue": "Not quite. Which bar represents a fraction that has 1 on top?",
              "audio_dir": "module_2/exit_check_msnlvi"
            }
          },
          {
            "@type": "Remediation",
            "id": "medium",
            "step": {
              "@type": "Step",
              "dialogue": "Here's what to focus on: one-third [event:application_task_md]  has one part shaded, two-thirds has two.",
              "audio_dir": "module_2/exit_check_zg4tdq"
            }
          },
          {
            "@type": "Remediation",
            "id": "heavy",
            "step": {
              "@type": "Step",
              "dialogue": "[event:application_task_hv] The word 'unit' is the key - it means [event:694af30ec882b664] ONE. Unit fractions always have a 1 on top.",
              "audio_dir": "module_2/exit_check_7ei0md"
            }
          }
        ],
        "on_correct": {
          "@type": "Step",
          "dialogue": "Yes. One part shaded [event:68faac54e1406735] makes it a unit fraction.",
          "audio_dir": "module_2/exit_check_240707990325769520"
        }
      }
    },
    {
