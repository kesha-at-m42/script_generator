  {
    "id": "ec_4_in_all",
    "beats": [
      {
        "type": "dialogue",
        "text": "Look at this Books Read This Week bar graph again. How many books did Ben and Cara read this week in all?",
        "_notion_block_id": "31b5917e-ac52-816e-815b-e1b217c16cb3"
      },
      {
        "type": "prompt",
        "text": "How many books did Ben and Cara read this week in all?",
        "tool": "multiple_choice",
        "options": [
          6,
          9,
          11,
          14
        ],
        "validator": [
          {
            "condition": {
              "selected": 11
            },
            "description": "Student selected 11 — correct, 5 plus 6 equals 11",
            "is_correct": true,
            "beats": [
              {
                "type": "dialogue",
                "text": "11 books in all. Ben read 5, Cara read 6. You added to combine and find the total.",
                "_notion_block_id": "31b5917e-ac52-810c-a955-d7e3b9ce364e"
              }
            ]
          },
          {
            "condition": {
              "selected": 6
            },
            "description": "Student selected 6 — only counted Cara's books, did not add Ben's",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "bar_graph_books",
                "params": {
                  "highlight_categories": [
                    "Ben",
                    "Cara"
                  ],
                  "description": "Highlight Ben, Cara on bar_graph_books"
                },
                "notion_flag": "updated",
                "_notion_block_id": "31b5917e-ac52-81a5-8d4d-fa6c464a054f"
              },
              {
                "type": "dialogue",
                "text": "You found Cara's 6 books. The question asks for Ben and Cara in all. We need to add both amounts together.",
                "_notion_block_id": "31b5917e-ac52-8199-823f-d57da761e703"
              }
            ]
          },
          {
            "condition": {
              "selected": 9
            },
            "description": "Student selected 9 — likely added Ben (5) and Dan (3) instead of Ben and Cara, or miscounted",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "bar_graph_books",
                "params": {
                  "highlight_categories": [
                    "Ben",
                    "Cara"
                  ],
                  "description": "Highlight Ben, Cara on bar_graph_books"
                },
                "notion_flag": "updated",
                "_notion_block_id": "31b5917e-ac52-8157-ae83-f903ac92d8cf"
              },
              {
                "type": "dialogue",
                "text": "Let's look at the right people. The question asks about Ben and Cara. Check which bars those are, then add the two numbers.",
                "_notion_block_id": "31b5917e-ac52-8118-9d63-d32ef85c96e3"
              }
            ]
          },
          {
            "condition": {
              "selected": 14
            },
            "description": "Student selected 14 — likely added Ava (8) and Cara (6) instead of Ben and Cara",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "bar_graph_books",
                "params": {
                  "highlight_categories": [
                    "Ben",
                    "Cara"
                  ],
                  "description": "Highlight Ben, Cara on bar_graph_books"
                },
                "notion_flag": "updated",
                "_notion_block_id": "31b5917e-ac52-81b9-a939-cb23976c1006"
              },
              {
                "type": "dialogue",
                "text": "Check the names carefully. The question asks about Ben and Cara. Find their bars, read the numbers, then combine.",
                "_notion_block_id": "31b5917e-ac52-8189-bfcf-da9151c8fb38"
              }
            ]
          },
          {
            "condition": {},
            "description": "Student answered incorrectly — system models the correct answer",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "animate",
                "tangible_id": "bar_graph_books",
                "params": {
                  "event": "highlight_and_label_sum",
                  "status": "confirmed",
                  "description": "Ben and Cara bars highlight. Ben's bar labeled 5, Cara's bar labeled 6. Addition equation 5 + 6 = 11 appears."
                },
                "_notion_block_id": "31b5917e-ac52-81a3-b043-f6b1311fc914"
              },
              {
                "type": "dialogue",
                "text": "Here is how we work through this problem. \"In all\" is a COMBINE problem. First, find Ben's bar: it shows 5 books. Then find Cara's bar: it shows 6 books. To combine, we add: 5 plus 6 equals 11. They read 11 books in all this week.",
                "_notion_block_id": "31b5917e-ac52-81c8-9eef-f8c1bd5e5e46"
              }
            ]
          }
        ],
        "_notion_block_id": "31b5917e-ac52-81c0-a799-edf0ab63e95b"
      },
