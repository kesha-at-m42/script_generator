  {
    "id": "ec_3_how_many_more",
    "beats": [
      {
        "type": "scene",
        "method": "PLACEHOLDER",
        "tangible_id": "PLACEHOLDER",
        "params": {
          "description": "Vertical bar graph appears. Books Read This Week data. Ava=8, Ben=5, Cara=6, Dan=3. Axis marked 0-8 by 1s."
        },
        "notion_flag": "suggested"
      },
      {
        "type": "dialogue",
        "text": "This bar graph shows the number of books read by four students this week. How many more books did Ava read than Dan?",
        "notion_flag": "suggested"
      },
      {
        "type": "prompt",
        "text": "How many more books did Ava read than Dan?",
        "tool": "multiple_choice",
        "options": [
          3,
          5,
          8,
          11
        ],
        "validator": [
          {
            "condition": {
              "selected": 5
            },
            "description": "Student selected 5 — correct, 8 minus 3 equals 5",
            "is_correct": true,
            "beats": [
              {
                "type": "dialogue",
                "text": "5 more books. Ava read 8, Dan read 3. The difference is 5.",
                "_notion_block_id": "31b5917e-ac52-81bd-a4fa-dc3e24297b1f"
              }
            ]
          },
          {
            "condition": {
              "selected": 3
            },
            "description": "Student selected 3 — confused Dan's value (3) with the difference between Ava and Dan",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "bar_graph_books",
                "params": {
                  "highlight_categories": [
                    "Ava",
                    "Dan"
                  ],
                  "description": "Highlight Ava, Dan on bar_graph_books"
                },
                "notion_flag": "updated",
                "_notion_block_id": "31b5917e-ac52-819f-b542-fa15102b7e62"
              },
              {
                "type": "dialogue",
                "text": "You found Dan's number of books. But we need the difference, how many more books Ava has read than Dan. Compare their bar heights.",
                "_notion_block_id": "31b5917e-ac52-81c9-beee-db776aa6bf20"
              }
            ]
          },
          {
            "condition": {
              "selected": 8
            },
            "description": "Student selected 8 — confused Ava's value (8) with the difference between Ava and Dan",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "bar_graph_books",
                "params": {
                  "highlight_categories": [
                    "Ava",
                    "Dan"
                  ],
                  "description": "Highlight Ava, Dan on bar_graph_books"
                },
                "notion_flag": "updated",
                "_notion_block_id": "31b5917e-ac52-81a8-84d0-c4540da382e7"
              },
              {
                "type": "dialogue",
                "text": "You found Ava's number of books. But the question asks how many more. We need to find the difference between Ava's 8 books and Dan's books.",
                "_notion_block_id": "31b5917e-ac52-8121-b968-cd348e362032"
              }
            ]
          },
          {
            "condition": {
              "selected": 11
            },
            "description": "Student selected 11 — added Ava's value and Dan's value (8 + 3) instead of finding the difference",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "bar_graph_books",
                "params": {
                  "highlight_categories": [
                    "Ava",
                    "Dan"
                  ],
                  "description": "Highlight Ava, Dan on bar_graph_books"
                },
                "notion_flag": "updated",
                "_notion_block_id": "31b5917e-ac52-815d-a64c-d17543b9fa16"
              },
              {
                "type": "dialogue",
                "text": "No, not exactly. When we ask “how many more,” we SUBTRACT to find the difference. Look at Ava's bar and Dan's bar: how much taller is Ava's?",
                "_notion_block_id": "31b5917e-ac52-81eb-ae89-d8eb378ef9ea"
              }
            ]
          },
          {
            "condition": {},
            "description": "Student answered incorrectly three or more times — system models the answer",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "animate",
                "tangible_id": "bar_graph_books",
                "params": {
                  "event": "show_difference",
                  "status": "confirmed",
                  "description": "Animation highlights Ava's bar at 8 and Dan's bar at 3, then visually shows the 5-unit difference between them"
                },
                "_notion_block_id": "31b5917e-ac52-8131-bf6b-c2d851004d5c"
              },
              {
                "type": "dialogue",
                "text": "Let me show you how this works. Ava read 8 books because her bar reaches to 8. Dan read 3 books since his bar reaches to 3. To find how many more, we subtract: 8 minus 3 equals 5. Ava read 5 more books than Dan.",
                "_notion_block_id": "31b5917e-ac52-8167-bd17-c5962a9a4fc7"
              }
            ]
          }
        ],
        "_notion_block_id": "31b5917e-ac52-8134-baa9-ed3a92c8bead"
      },
      {
        "type": "current_scene",
        "elements": [
          {
            "tangible_id": "bar_graph_books",
            "description": "Vertical bar graph in reading mode. Books Read This Week data. Ava=8, Ben=5, Cara=6, Dan=3. Axis 0-8. Multiple choice prompt active.",
            "tangible_type": "bar_graph",
            "mode": "reading",
            "orientation": "vertical",
            "categories": [
              "Ava",
              "Ben",
              "Cara",
              "Dan"
            ],
            "values": [
              8,
              5,
              6,
              3
            ]
          }
        ],
        "_notion_block_id": "31b5917e-ac52-81cf-938d-c3243eba7088",
        "_toml_key": "step_102_ec_3_how_many_more"
      },
      {
        "type": "unparsed",
        "_notion_block_id": "31b5917e-ac52-811a-9b95-f9553678d4f8",
        "notion_type": "divider"
      }
    ],
    "_toml_key": "section_102_ec_3_how_many_more"
