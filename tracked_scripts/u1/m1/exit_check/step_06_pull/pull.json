  {
    "id": "ec_2_find_fewest",
    "beats": [
      {
        "type": "scene",
        "method": "PLACEHOLDER",
        "tangible_id": "PLACEHOLDER",
        "params": {
          "description": "Horizontal bar graph appears. Favorite Seasons data. Spring=6, Summer=9, Fall=4, Winter=5. Axis marked 0-10 by 1s."
        },
        "notion_flag": "suggested"
      },
      {
        "type": "dialogue",
        "text": "Look at this Favorite Seasons bar graph. Click on which season the fewest students like.",
        "_notion_block_id": "31b5917e-ac52-81ea-8e33-db3efbe22fa6"
      },
      {
        "type": "prompt",
        "text": "Click on which season the fewest students like.",
        "tool": "click_category",
        "target": "bar_graph_seasons",
        "validator": [
          {
            "condition": {
              "selected": "Fall"
            },
            "description": "Student clicked Fall — correct, 4 votes is the fewest",
            "is_correct": true,
            "beats": [
              {
                "type": "dialogue",
                "text": "That's it. Fall shows the fewest, only 4 votes.",
                "_notion_block_id": "31b5917e-ac52-8127-8246-f1cb1478f721"
              }
            ]
          },
          {
            "condition": {
              "incorrect_count": 1
            },
            "description": "Student clicked a wrong category on first attempt",
            "is_correct": false,
            "beats": [
              {
                "type": "dialogue",
                "text": "That's not it. Look for the shortest bar. That will show the fewest votes.",
                "_notion_block_id": "31b5917e-ac52-819c-8a14-f1d5ce20a0ce"
              }
            ]
          },
          {
            "condition": {
              "incorrect_count": 2
            },
            "description": "Student clicked a wrong category on second attempt",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "bar_graph_seasons",
                "params": {
                  "highlight_categories": [
                    "Fall"
                  ],
                  "description": "Highlight Fall on bar_graph_seasons"
                },
                "notion_flag": "updated",
                "_notion_block_id": "31b5917e-ac52-81ac-ae00-c583e061402c"
              },
              {
                "type": "dialogue",
                "text": " Not that one. The fewest means the smallest number. Which bar is shorter than all the others?",
                "_notion_block_id": "31b5917e-ac52-81e1-bb41-db31bd19e49f"
              }
            ]
          },
          {
            "condition": {},
            "description": "Student clicked a wrong category three or more times — system models the answer",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "animate",
                "tangible_id": "bar_graph_seasons",
                "params": {
                  "event": "highlight_shortest_bar",
                  "status": "confirmed",
                  "description": "Fall bar pulses and highlights, showing it as the shortest at 4 votes"
                },
                "_notion_block_id": "31b5917e-ac52-818c-8dce-febf61298540"
              },
              {
                "type": "dialogue",
                "text": "Let's look at it together. To find the fewest, we look for the shortest bar. Spring goes to 6, Summer to 9, Fall to 4, and Winter to 5. Fall has the shortest bar at 4 votes, that's the fewest.",
                "_notion_block_id": "31b5917e-ac52-817d-9c97-f453d752124a"
              }
            ]
          }
        ],
        "_notion_block_id": "31b5917e-ac52-81fb-80fc-f4e6462a1e65"
      },
      {
        "type": "current_scene",
        "elements": [
          {
            "tangible_id": "bar_graph_seasons",
            "description": "Horizontal bar graph in reading mode. Favorite Seasons data. Spring=6, Summer=9, Fall=4, Winter=5. Axis 0-10. Click category tool active.",
            "tangible_type": "bar_graph",
            "mode": "reading",
            "orientation": "horizontal",
            "categories": [
              "Spring",
              "Summer",
              "Fall",
              "Winter"
            ],
            "values": [
              6,
              9,
              4,
              5
            ]
          }
        ],
        "_notion_block_id": "31b5917e-ac52-8110-abea-ff8c0d4c0f8e",
        "_toml_key": "step_101_ec_2_find_fewest"
      },
