          "type": "prompt",
          "text": "Which of these describes what a 'scale' on a graph means?",
          "tool": "multiple_choice",
          "options": [
            "How many items each symbol shows",
            "How many symbols are on the graph",
            "How many categories there are",
            "The size of the symbols"
          ],
          "validator": [
            {
              "condition": {
                "selected": "How many items each symbol shows"
              },
              "description": "Student selected 'How many items each symbol shows' — correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Scale tells you how many items each symbol shows. Scale of 1 means each symbol is 1. Scale of 2 means each symbol is 2."
                  },
                  {
                    "type": "dialogue",
                    "text": "When you see a graph, always check the key first. The key tells you the scale."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "picture_graph_pets_scale1",
                        "description": "Picture graph at scale of 1. Pets data. Key visible.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
