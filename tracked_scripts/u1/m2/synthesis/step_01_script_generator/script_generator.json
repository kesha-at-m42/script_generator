[
  {
    "id": "s5_opening_frame",
    "type": "transition",
    "scene": [],
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "You made scaled picture graphs. You used half-symbols for odd numbers. Now let's see WHY scaled graphs are useful."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s5_1_scale_toggle",
    "scene": [],
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "data_table",
          "tangible_type": "data_table",
          "params": {
            "categories": [
              "Cats",
              "Dogs",
              "Birds",
              "Fish"
            ],
            "values": [
              8,
              6,
              10,
              4
            ],
            "description": "Data table appears showing Cats=8, Dogs=6, Birds=10, Fish=4."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_pets",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 2,
            "categories": [
              "Cats",
              "Dogs",
              "Birds",
              "Fish"
            ],
            "values": [
              8,
              6,
              10,
              4
            ],
            "description": "Horizontal picture graph appears alongside data table. Pets data. Scale of 2. Cats=4 symbols, Dogs=3 symbols, Birds=5 symbols, Fish=2 symbols. Key visible: Each ⭐ = 2. Scale toggle control visible with options: Each ⭐ = 1 and Each ⭐ = 2."
          }
        },
        {
          "type": "dialogue",
          "text": "Here's data you know — and a graph with scale of 2. But watch what happens when you change the scale."
        },
        {
          "type": "prompt",
          "text": "Toggle the scale to 1. What happens to the graph?",
          "tool": "click_component",
          "target": "picture_graph_pets.scale_toggle",
          "validator": [
            {
              "condition": {},
              "description": "Student toggles scale from 2 to 1 — graph transforms",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "picture_graph_pets",
                    "params": {
                      "event": "scale_toggle_animation",
                      "status": "confirmed",
                      "description": "Symbols double in count. Cats: 4 symbols → 8 symbols, Dogs: 3 → 6, Birds: 5 → 10, Fish: 2 → 4. Key updates to Each ⭐ = 1. Animation shows symbols appearing smoothly."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Look at that! Cats went from 4 symbols to 8. Same 8 cats — but now every cat gets its own symbol."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table",
                        "description": "Data table showing Cats=8, Dogs=6, Birds=10, Fish=4.",
                        "tangible_type": "data_table"
                      },
                      {
                        "tangible_id": "picture_graph_pets",
                        "description": "Picture graph now at scale of 1. Cats=8 symbols, Dogs=6 symbols, Birds=10 symbols, Fish=4 symbols. Key shows Each ⭐ = 1.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "scale": 1,
                        "categories": [
                          "Cats",
                          "Dogs",
                          "Birds",
                          "Fish"
                        ]
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "data_table",
              "description": "Data table showing Cats=8, Dogs=6, Birds=10, Fish=4.",
              "tangible_type": "data_table"
            },
            {
              "tangible_id": "picture_graph_pets",
              "description": "Picture graph at scale of 2. Scale toggle control active. Key visible: Each ⭐ = 2.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "scale": 2,
              "categories": [
                "Cats",
                "Dogs",
                "Birds",
                "Fish"
              ]
            }
          ]
        }
      ],
      [
        {
          "type": "dialogue",
          "text": "Now toggle back to scale of 2."
        },
        {
          "type": "prompt",
          "text": "Which scale uses fewer symbols?",
          "tool": "multiple_choice",
          "options": [
            "Scale of 1",
            "Scale of 2"
          ],
          "validator": [
            {
              "condition": {
                "selected": "Scale of 2"
              },
              "description": "Student selected Scale of 2 — correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "picture_graph_pets",
                    "params": {
                      "event": "scale_toggle_animation",
                      "status": "confirmed",
                      "description": "Symbols halve in count. Cats: 8 symbols → 4 symbols, Dogs: 6 → 3, Birds: 10 → 5, Fish: 4 → 2. Key updates to Each ⭐ = 2."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Scale of 2 — fewer symbols, same data. That's what makes scaled graphs efficient."
                  },
                  {
                    "type": "dialogue",
                    "text": "You just saw the same data change shape. The INFORMATION stays the same — only the number of symbols changes. That's the power of scale."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table",
                        "description": "Data table showing Cats=8, Dogs=6, Birds=10, Fish=4.",
                        "tangible_type": "data_table"
                      },
                      {
                        "tangible_id": "picture_graph_pets",
                        "description": "Picture graph back at scale of 2. Cats=4 symbols, Dogs=3, Birds=5, Fish=2. Key shows Each ⭐ = 2.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "scale": 2,
                        "categories": [
                          "Cats",
                          "Dogs",
                          "Birds",
                          "Fish"
                        ]
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "data_table",
              "description": "Data table showing Cats=8, Dogs=6, Birds=10, Fish=4.",
              "tangible_type": "data_table"
            },
            {
              "tangible_id": "picture_graph_pets",
              "description": "Picture graph at scale of 1. Cats=8 symbols, Dogs=6, Birds=10, Fish=4. Multiple choice prompt active.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "scale": 1,
              "categories": [
                "Cats",
                "Dogs",
                "Birds",
                "Fish"
              ]
            }
          ]
        }
