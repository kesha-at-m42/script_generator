  {
    "id": "s5_2_half_symbol_mastery",
    "scene": [],
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "data_table"
        },
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "picture_graph_pets"
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_numbers",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 2,
            "description": "New picture graph context appears. Key visible: Each symbol = 2. No data table visible. Clean display showing the key prominently."
          }
        },
        {
          "type": "dialogue",
          "text": "You learned about half-symbols. If you made a graph using this key, which numbers would need a half-symbol?"
        },
        {
          "type": "prompt",
          "text": "If you made a graph with scale of 2, which numbers would need a half-symbol? Select all that apply.",
          "tool": "multi_select",
          "options": [
            "8",
            "7",
            "12",
            "9"
          ],
          "validator": [
            {
              "condition": {
                "and": [
                  {
                    "selected": "7"
                  },
                  {
                    "selected": "9"
                  }
                ]
              },
              "description": "Student selected 7 and 9 — correct, both odd numbers",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "7 and 9 are ODD numbers. They don't split evenly into groups of 2, so they need a half-symbol for the leftover 1."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "picture_graph_numbers",
                        "description": "Picture graph with key visible. Scale of 2. 7 and 9 highlighted as selected.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "scale": 2
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "picture_graph_numbers",
              "description": "Picture graph with key visible: Each symbol = 2. Multi-select prompt active with options 8, 7, 12, 9.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "scale": 2
            }
          ]
        }
      ],
      [
        {
          "type": "dialogue",
          "text": "What does a half-symbol show?"
        },
        {
          "type": "prompt",
          "text": "What does a half-symbol show?",
          "tool": "multiple_choice",
          "options": [
            "Half of 2, which is 1",
            "Half of the total",
            "2 items",
            "Nothing—it's decoration"
          ],
          "validator": [
            {
              "condition": {
                "selected": "Half of 2, which is 1"
              },
              "description": "Student selected 'Half of 2, which is 1' — correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Half of 2 is 1. A half-symbol shows 1 item. That's how we show odd numbers exactly — the full symbols show groups of 2, the half shows the 1 left over."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "picture_graph_numbers",
                        "description": "Picture graph with key visible. Scale of 2.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "scale": 2
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "picture_graph_numbers",
              "description": "Picture graph with key visible. Multiple choice prompt active asking what a half-symbol shows.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "scale": 2
            }
          ]
        }
      ]
    ]
  },
