        },
        "id": "s5_2_half_symbol_mastery_b2",
        "_notion_block_id": "3485917e-ac52-8138-869d-fe1313316553"
      },
      {
        "type": "dialogue",
        "text": "You learned about half-symbols. If you made a graph using this key, which numbers would need a half-symbol? Select ALL that need half symbols.",
        "id": "s5_2_half_symbol_mastery_b3",
        "_notion_block_id": "3485917e-ac52-81a2-bdd6-e8c9a98f88ba"
      },
      {
        "type": "prompt",
        "text": "If you made a graph with scale of 2, which numbers would need a half-symbol? Select ALL that apply.",
        "tool": "multi_select",
        "options": [
          "8",
          "7",
          "12",
          "9"
        ],
        "validator": [
          {
            "condition": {
