            ]
          },
          {
            "condition": {
              "and": [
                {
                  "or": [
                    {
                      "selected": "7"
                    },
                    {
                      "selected": "9"
                    }
                  ]
                },
                {
                  "not": {
                    "and": [
                      {
                        "selected": "7"
                      },
                      {
                        "selected": "9"
                      }
                    ]
                  }
                }
              ]
            },
            "description": "Branch 2: Student selected only 7 or only 9 (correct answers only, but not all)",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "description": "The selected odd number highlights."
                },
                "id": "s5_2_half_symbol_mastery_b4_v1_b0",
                "_notion_block_id": "3485917e-ac52-8139-b9b5-cc3d06657069"
              },
              {
                "type": "dialogue",
                "text": "You found an odd number. Odd numbers need half-symbols because they don't split evenly into groups of 2. Are there any other odd numbers in the list?",
                "id": "s5_2_half_symbol_mastery_b4_v1_b1",
                "_notion_block_id": "3485917e-ac52-8153-be22-e2ca51613dcb"
              }
            ]
          },
          {
            "condition": {
              "and": [
                {
                  "or": [
                    {
                      "selected": "8"
                    },
                    {
                      "selected": "12"
                    }
                  ]
                },
                {
                  "not": {
                    "or": [
                      {
                        "selected": "7"
                      },
                      {
                        "selected": "9"
                      }
                    ]
                  }
                }
              ]
            },
            "description": "Branch 3: Student selected only even numbers (all wrong, no correct answers)",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "description": "Key pulses: Each symbol = 2."
                },
                "id": "s5_2_half_symbol_mastery_b4_v2_b0",
                "_notion_block_id": "3485917e-ac52-81dd-b1ac-d753f613beef"
              },
              {
                "type": "dialogue",
                "text": "Even numbers split perfectly into groups of 2 so they use whole symbols. Half-symbols are for numbers that DON'T split evenly. Which numbers leave 1 leftover when you group by 2?",
                "id": "s5_2_half_symbol_mastery_b4_v2_b1",
                "_notion_block_id": "3485917e-ac52-811c-9dea-ea4b70e4154d"
              }
            ]
          },
          {
            "condition": {
              "and": [
                {
                  "or": [
                    {
                      "selected": "7"
                    },
                    {
                      "selected": "9"
                    }
                  ]
                },
                {
                  "or": [
                    {
                      "selected": "8"
                    },
                    {
                      "selected": "12"
                    }
                  ]
                }
              ]
            },
            "description": "Branch 4: Student selected mix of odd and even numbers",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "description": "Odd numbers in the list pulse briefly."
                },
                "id": "s5_2_half_symbol_mastery_b4_v3_b0",
                "_notion_block_id": "3485917e-ac52-813a-8e18-ca50e1941328"
              },
              {
                "type": "dialogue",
                "text": "You found odd numbers. Those DO need half-symbols. But even numbers split perfectly into groups of 2 so they use whole symbols. Which selections don't belong?",
                "id": "s5_2_half_symbol_mastery_b4_v3_b1",
                "_notion_block_id": "3485917e-ac52-81dd-a70e-f394a015058b"
              }
            ]
          },
          {
            "condition": {},
            "description": "Student answered incorrectly. System models the correct answer.",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "animate",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "event": "highlight_options",
                  "status": "confirmed",
                  "description": "7 and 9 highlight and pulse to confirm they are the odd numbers.",
                  "options": [
                    "7",
                    "9"
                  ]
                },
                "id": "s5_2_half_symbol_mastery_b4_v4_b0",
                "_notion_block_id": "3485917e-ac52-8169-942b-df9a0d0f9776"
              },
              {
                "type": "dialogue",
                "text": "Let me show you. For a scale of 2, we group by 2s to make whole symbols. 8 splits evenly: 4 groups of 2. 12 splits evenly: 6 groups of 2. These are {even} numbers and need whole symbols. But 7 is 3 groups of 2 plus 1 leftover. 9 is 4 groups of 2 plus 1 leftover. The answers are 7 and 9. {Odd} numbers need half-symbols because they always have 1 left over.",
                "id": "s5_2_half_symbol_mastery_b4_v4_b1",
                "_notion_block_id": "3485917e-ac52-810d-8435-db482f2599b6"
              }
            ]
          }
        ],
        "id": "s5_2_half_symbol_mastery_b4",
        "_notion_block_id": "3485917e-ac52-81df-b69d-d9a36cf94a2d"
      },
      {
        "type": "current_scene",
        "elements": [
          {
            "tangible_id": "picture_graph_numbers",
            "description": "Picture graph with key visible: Each symbol = 2. Multi-select prompt active with options 8, 7, 12, 9.",
            "tangible_type": "picture_graph",
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 2
          }
        ],
        "id": "s5_2_half_symbol_mastery_b5",
        "_notion_block_id": "3485917e-ac52-81d4-978a-c3401fbf9ed1",
        "_toml_key": "step_103_half_symbol_mastery"
      },
      {
        "type": "dialogue",
        "text": "What does a half-symbol show?",
        "id": "s5_2_half_symbol_mastery_b6",
        "_notion_block_id": "3485917e-ac52-8182-b71b-f58e98611ed7"
      },
      {
        "type": "prompt",
        "text": "What does a half-symbol show?",
        "tool": "multiple_choice",
        "options": [
          "Half of 2, which is 1",
          "Half of the total",
          "2 items",
          "Nothing—it's decoration"
        ],
        "validator": [
          {
            "condition": {
              "selected": "Half of 2, which is 1"
            },
            "description": "Student selected 'Half of 2, which is 1' — correct",
            "is_correct": true,
            "beats": [
              {
                "type": "dialogue",
                "text": "Half of 2 is 1. A half-symbol shows 1 item. That's how we show odd numbers exactly. The full symbols show groups of 2, the half shows the 1 left over.",
                "id": "s5_2_half_symbol_mastery_b7_v0_b0",
                "_notion_block_id": "3485917e-ac52-81ca-901e-ee5fca8297f1"
              }
            ]
          },
          {
            "condition": {
              "selected": "Half of the total"
            },
            "description": "Student selected 'Half of the total': misconception that half-symbol relates to total count",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "description": "Key pulses: Each symbol = 2."
                },
                "id": "s5_2_half_symbol_mastery_b7_v1_b0",
                "_notion_block_id": "3485917e-ac52-8120-ab88-ed702741bfca"
              },
              {
                "type": "dialogue",
                "text": "A half-symbol doesn't show half of the total. It shows half of what ONE symbol is worth. Look at the key. Each symbol equals 2. What is half of 2?",
                "id": "s5_2_half_symbol_mastery_b7_v1_b1",
                "_notion_block_id": "3485917e-ac52-81b4-bf89-c58fe7a49bc6"
              }
            ]
          },
          {
            "condition": {
              "selected": "2 items"
            },
            "description": "Student selected '2 items': confused half-symbol with full symbol",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "description": "Key pulses: Each symbol = 2."
                },
                "id": "s5_2_half_symbol_mastery_b7_v2_b0",
                "_notion_block_id": "3485917e-ac52-8165-a021-f3ed7231ec2d"
              },
              {
                "type": "dialogue",
                "text": "A full symbol shows 2 items. A HALF-symbol shows half of that. If a full symbol is 2, what is half of 2?",
                "id": "s5_2_half_symbol_mastery_b7_v2_b1",
                "_notion_block_id": "3485917e-ac52-8144-99da-f5002737bb1e"
              }
            ]
          },
          {
            "condition": {
              "selected": "Nothing—it's decoration"
            },
            "description": "Student selected 'Nothing—it's decoration': does not understand half-symbols have meaning",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "update",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "description": "Key highlights: Each symbol = 2."
                },
                "id": "s5_2_half_symbol_mastery_b7_v3_b0",
                "_notion_block_id": "3485917e-ac52-817a-b41c-d16f6134e4bf"
              },
              {
                "type": "dialogue",
                "text": "Half-symbols have real meaning. That's how we show odd numbers exactly. When the scale is 2, a full symbol shows 2 items. A half-symbol shows half of that. What is half of 2?",
                "id": "s5_2_half_symbol_mastery_b7_v3_b1",
                "_notion_block_id": "3485917e-ac52-811d-bbf4-fb035fc724f1"
              }
            ]
          },
          {
            "condition": {},
            "description": "Student answered incorrectly. System models the correct answer.",
            "is_correct": false,
            "beats": [
              {
                "type": "scene",
                "method": "animate",
                "tangible_id": "picture_graph_numbers",
                "params": {
                  "event": "demonstrate_half_symbol",
                  "status": "confirmed",
                  "description": "Key animates: full symbol labeled '2', half-symbol labeled '1'."
                },
                "id": "s5_2_half_symbol_mastery_b7_v4_b0",
                "_notion_block_id": "3485917e-ac52-816a-bc0f-e4de8edf0714"
              },
              {
                "type": "dialogue",
                "text": "Here's how it works. The key says each symbol equals 2. So a whole symbol equal 2 and a half-symbol equals half of 2, which is 1. That's how we show the leftover 1 when we have an odd number. A half-symbol shows half of the scale.'",
                "id": "s5_2_half_symbol_mastery_b7_v4_b1",
                "_notion_block_id": "3485917e-ac52-81e2-babb-fc3497687ac6"
              }
