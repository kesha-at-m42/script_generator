[
  {
    "id": "s1_1_graph_reading_scale_2",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_activities",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 2,
            "categories": [
              "Soccer",
              "Basketball",
              "Tennis",
              "Swimming"
            ],
            "values": [
              12,
              7,
              6,
              11
            ],
            "axis_range": [
              0,
              14
            ],
            "title": "After-School Activities",
            "description": "Horizontal bar graph appears. After-School Activities data. Scale of 2. Soccer=12, Basketball=7, Tennis=6, Swimming=11. Axis shows 0, 2, 4, 6, 8, 10, 12, 14."
          }
        },
        {
          "type": "dialogue",
          "text": "Let's warm up your graph skills. Here's a bar graph. Check the scale first."
        },
        {
          "type": "prompt",
          "text": "How many students chose soccer?",
          "tool": "multiple_choice",
          "options": [
            6,
            10,
            12,
            24
          ],
          "validator": [
            {
              "condition": {
                "selected": 12
              },
              "description": "Student selected 12, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "12 students. Scale of 2—each mark on the axis shows 2 students."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "bar_graph_activities",
                        "description": "Horizontal bar graph. After-School Activities. Scale of 2. Soccer=12, Basketball=7, Tennis=6, Swimming=11.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "scale": 2,
                        "categories": [
                          "Soccer",
                          "Basketball",
                          "Tennis",
                          "Swimming"
                        ]
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 6
              },
              "description": "Student selected 6, counted marks instead of using scale of 2",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You counted the marks. Each mark stands for 2 students, not 1. Count by 2s along the Soccer bar."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 10
              },
              "description": "Student selected 10, read axis incorrectly or estimated",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. The Soccer bar goes all the way to the 12 mark. The scale is 2, so the last mark the bar touches is 12."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 24
              },
              "description": "Student selected 24, multiplied 12 by 2 instead of reading the value",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Here's a hint: the scale of 2 tells us how to read the axis. It doesn't mean we multiply the bar's value. Where does the Soccer bar end?"
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "event": "trace_bar_to_axis",
                      "status": "confirmed",
                      "description": "Soccer bar traces to axis, landing on 12",
                      "category": "Soccer"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you how this works. The Soccer bar reaches the 12 mark on the axis. With a scale of 2, the numbers go 0, 2, 4, 6, 8, 10, 12. The bar ends at 12, so 12 students chose soccer."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar_graph_activities",
              "description": "Horizontal bar graph in reading mode. After-School Activities data. Scale of 2. Soccer=12, Basketball=7, Tennis=6, Swimming=11. Multiple choice tool active.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "scale": 2,
              "categories": [
                "Soccer",
                "Basketball",
                "Tennis",
                "Swimming"
              ]
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_2_comparison_single_step",
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "Now a question about this data."
        },
        {
          "type": "prompt",
          "text": "How many more students chose soccer than tennis?",
          "tool": "multiple_choice",
          "options": [
            18,
            12,
            6,
            3
          ],
          "validator": [
            {
              "condition": {
                "selected": 6
              },
              "description": "Student selected 6, correct (12 minus 6)",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "6 more. 'How many more' means compare—we subtract. Soccer is 12, tennis is 6, difference is 6."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "bar_graph_activities",
                        "description": "Horizontal bar graph. After-School Activities. Scale of 2. Soccer=12, Basketball=7, Tennis=6, Swimming=11.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "scale": 2,
                        "categories": [
                          "Soccer",
                          "Basketball",
                          "Tennis",
                          "Swimming"
                        ]
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 18
              },
              "description": "Student selected 18: added the two values instead of subtracting",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "highlight_categories": [
                        "Soccer",
                        "Tennis"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're working on it. Here's what helps: 'how many more' means find the difference between the two numbers, not the total."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 12
              },
              "description": "Student selected 12: chose the larger value instead of finding the difference",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. That's how many chose soccer. We need to compare it to tennis. How much bigger is 12 than 6?"
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 3
              },
              "description": "Student selected 3: possibly misread the scale or divided instead of subtracting",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "highlight_categories": [
                        "Soccer",
                        "Tennis"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're getting there. The key is to subtract the tennis value from the soccer value. Count the spaces between 6 and 12."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "bar_graph_activities",
                    "params": {
                      "event": "highlight_comparison",
                      "status": "confirmed",
                      "description": "Soccer bar and Tennis bar highlight. Visual shows 12 minus 6 equals 6."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you how this works. Soccer has 12 students. Tennis has 6 students. When we subtract 6 from 12, we get 6. That's how many more chose soccer."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar_graph_activities",
              "description": "Horizontal bar graph. After-School Activities data. Scale of 2. Soccer=12, Basketball=7, Tennis=6, Swimming=11. Multiple choice tool active.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "scale": 2,
              "categories": [
                "Soccer",
                "Basketball",
                "Tennis",
                "Swimming"
              ]
            }
          ]
        }
      ]
    ]
