  {
    "id": "s1_w2_scale_comparison",
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "minis_counting_scene"
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_scale2",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 2,
            "categories": [
              "Red",
              "Blue",
              "Yellow"
            ],
            "values": [
              20,
              25,
              15
            ],
            "description": "Vertical picture graph appears on the left side of screen. Shows Minis data with scale of 2. Key visible: Each ⭐ = 2. Red has 10 symbols (including half), Blue has 12.5 symbols (including half), Yellow has 7.5 symbols (including half)."
          }
        },
        {
          "type": "dialogue",
          "text": "Here's your data with scale of 2. Each symbol shows 2 items."
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_scale5",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 5,
            "categories": [
              "Red",
              "Blue",
              "Yellow"
            ],
            "values": [
              20,
              25,
              15
            ],
            "description": "Vertical picture graph appears on the right side of screen. Shows same Minis data with scale of 5. Key visible: Each ⭐ = 5. Red has 4 symbols, Blue has 5 symbols, Yellow has 3 symbols. Noticeably fewer symbols than the left graph."
          }
        },
        {
          "type": "dialogue",
          "text": "And here's the SAME data with scale of 5. Each symbol shows 5 items. Same data. Same totals. But look at the graphs."
        },
        {
          "type": "prompt",
          "text": "What do you notice about the two graphs?",
          "tool": "multiple_choice",
          "options": [
            "The scale-of-5 graph has fewer symbols",
            "The scale-of-5 graph has more symbols",
            "They have the same number of symbols",
            "The graphs show different data"
          ],
          "validator": [
            {
              "condition": {
                "selected": "The scale-of-5 graph has fewer symbols"
              },
              "description": "Student identified fewer symbols on scale-of-5 graph, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Fewer symbols for the same data. When each symbol shows MORE, you need FEWER of them."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "picture_graph_scale2",
                        "description": "Vertical picture graph on left. Scale of 2. Red=20 (10 symbols), Blue=25 (12.5 symbols), Yellow=15 (7.5 symbols). Key: Each ⭐ = 2.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 2,
                        "categories": [
                          "Red",
                          "Blue",
                          "Yellow"
                        ]
                      },
                      {
                        "tangible_id": "picture_graph_scale5",
                        "description": "Vertical picture graph on right. Scale of 5. Red=20 (4 symbols), Blue=25 (5 symbols), Yellow=15 (3 symbols). Key: Each ⭐ = 5.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 5,
                        "categories": [
                          "Red",
                          "Blue",
                          "Yellow"
                        ]
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "The scale-of-5 graph has more symbols"
              },
              "description": "Student selected that scale-of-5 has more symbols, opposite of correct answer",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_scale5",
                    "params": {
                      "highlight_categories": [
                        "Blue"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's count together. Look at Blue on the right graph. Count the symbols. Now look at Blue on the left. Which column has fewer symbols?"
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "They have the same number of symbols"
              },
              "description": "Student thinks both graphs have the same number of symbols",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_scale2",
                    "params": {
                      "highlight_categories": [
                        "Red"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Here's what helps: count the Red symbols on each graph. The left graph has many more symbols than the right, even though both show 20 items."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "The graphs show different data"
              },
              "description": "Student thinks the graphs show different data sets",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_scale2",
                    "params": {
                      "highlight_categories": [
                        "Red",
                        "Blue",
                        "Yellow"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're working on it. Both graphs show the exact same Minis data. Red is 20, Blue is 25, Yellow is 15 on both. The difference is how many items each symbol represents."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "picture_graph_scale2",
                    "params": {
                      "event": "count_symbols",
                      "status": "confirmed",
                      "description": "System counts symbols in Blue column on left graph: 12.5 symbols light up one by one",
                      "category": "Blue"
                    }
                  },
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "picture_graph_scale5",
                    "params": {
                      "event": "count_symbols",
                      "status": "confirmed",
                      "description": "System counts symbols in Blue column on right graph: 5 symbols light up one by one",
                      "category": "Blue"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you. I'll count Blue on both. The left graph has 12 and a half symbols. The right graph has only 5 symbols. The scale-of-5 graph has fewer symbols because each one shows more items."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "picture_graph_scale2",
              "description": "Vertical picture graph on left. Scale of 2. Red, Blue, Yellow categories. Key: Each ⭐ = 2.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 2,
              "categories": [
                "Red",
                "Blue",
                "Yellow"
              ]
            },
            {
              "tangible_id": "picture_graph_scale5",
              "description": "Vertical picture graph on right. Scale of 5. Red, Blue, Yellow categories. Key: Each ⭐ = 5.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 5,
              "categories": [
                "Red",
                "Blue",
                "Yellow"
              ]
            }
          ]
        }
      ]
    ]
  },
