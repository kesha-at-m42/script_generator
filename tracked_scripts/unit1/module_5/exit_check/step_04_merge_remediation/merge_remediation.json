[
  {
    "id": "s1_transition_exit_check",
    "type": "transition",
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "bar_graph_lesson_final",
          "params": {
            "description": "Lesson graph clears from screen."
          }
        },
        {
          "type": "dialogue",
          "text": "You learned to choose scales. You checked if the biggest number fits. You checked the last digits. Let's see what you know."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s1_ec1_scale_too_small",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "data_table_ec1",
          "tangible_type": "data_table",
          "params": {
            "description": "Vertical data table appears. Toys Collected: Amy 45, Ben 70, Cora 15, Dan 30."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "scale_preview_ec1",
          "tangible_type": "scale_preview",
          "params": {
            "description": "Four scale options displayed. Scale of 1: red X, '70 doesn't fit'. Scale of 2: red X, '70 doesn't fit'. Scale of 5: red X, '70 doesn't fit'. Scale of 10: green checkmark.",
            "scales": [
              1,
              2,
              5,
              10
            ],
            "max_value": 70,
            "feedback": {
              "1": "doesn't fit",
              "2": "doesn't fit",
              "5": "doesn't fit",
              "10": "fits"
            }
          }
        },
        {
          "type": "dialogue",
          "text": "Four friends collected toys for a donation drive. Ben collected the most with 70 toys. Which scale works best for this data?"
        },
        {
          "type": "prompt",
          "text": "Which scale works best for this data?",
          "tool": "multiple_choice",
          "options": [
            "Scale of 1",
            "Scale of 2",
            "Scale of 5",
            "Scale of 10"
          ],
          "validator": [
            {
              "condition": {
                "selected": "Scale of 10"
              },
              "description": "Student selected Scale of 10, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Scale of 10. For data up to 70, Scale of 2 would need too many lines and Scale of 5 would need fewer, but still many lines. Scale of 10 only needs 8. Much easier to read."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table_ec1",
                        "description": "Vertical data table. Toys Collected: Amy 45, Ben 70, Cora 15, Dan 30.",
                        "tangible_type": "data_table"
                      },
                      {
                        "tangible_id": "scale_preview_ec1",
                        "description": "Scale preview showing Scale of 10 as the working choice.",
                        "tangible_type": "scale_preview"
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Scale of 1"
              },
              "description": "Student selected Scale of 1: doesn't recognize that the scale won't fit the data",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "scale_preview_ec1",
                    "params": {
                      "highlight_scales": [
                        1
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. Ben collected 70 toys. Scale of 1 would need 70 lines on your graph. That's way too many to fit."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Scale of 2"
              },
              "description": "Student selected Scale of 2: doesn't recognize that the scale won't fit the data",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "scale_preview_ec1",
                    "params": {
                      "highlight_scales": [
                        2
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're working on it. Scale of 2 would need 35 lines to reach 70. That's still too many lines to fit on one graph."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Scale of 5"
              },
              "description": "Student selected Scale of 5: doesn't recognize that the scale won't fit the data",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "scale_preview_ec1",
                    "params": {
                      "highlight_scales": [
                        5
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're getting there. The key is that Scale of 5 would need 14 lines to show 70. That's better than 1 or 2, but still won't fit."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "scale_preview_ec1",
                    "params": {
                      "event": "highlight_correct_scale",
                      "status": "confirmed",
                      "description": "Scale of 10 highlights and pulses to show it's the correct choice"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you how this works. Ben collected 70 toys, the highest number. Scale of 10 only needs 8 lines to reach 70. Scales of 1, 2, and 5 all need too many lines. Scale of 10 fits best."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "data_table_ec1",
              "description": "Vertical data table. Toys Collected: Amy 45, Ben 70, Cora 15, Dan 30.",
              "tangible_type": "data_table"
            },
            {
              "tangible_id": "scale_preview_ec1",
              "description": "Four scale options displayed with fit indicators for max value 70.",
              "tangible_type": "scale_preview"
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_ec2_non_multiples_need_scale_2",
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "data_table_ec1",
          "params": {
            "description": "Previous data table clears."
          }
        },
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "scale_preview_ec1",
          "params": {
            "description": "Previous scale preview clears."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "data_table_ec2",
          "tangible_type": "data_table",
          "params": {
            "description": "Horizontal data table appears. Minutes Reading: Gus 23, Hal 31, Eli 9, Fay 16."
          }
        },
        {
          "type": "dialogue",
          "text": "These students tracked how many minutes they read this week. Check the numbers: 23, 31, 9, 16. Which scale will show ALL these values exactly?"
        },
        {
          "type": "prompt",
          "text": "Which scale will show ALL these values exactly?",
          "tool": "multiple_choice",
          "options": [
            "Scale of 2",
            "Scale of 5",
            "Scale of 10"
          ],
          "validator": [
            {
              "condition": {
                "selected": "Scale of 2"
              },
              "description": "Student selected Scale of 2, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Scale of 2. The biggest value of 31 could work with Scale of 2 or Scale of 5. Then check those digits in the ones place: 3, 1, 9, 6. None are 0 or 5 so they aren't multiples of 5. That's your Scale of 2 signal to show the exact values on the graph."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table_ec2",
                        "description": "Horizontal data table. Minutes Reading: Gus 23, Hal 31, Eli 9, Fay 16.",
                        "tangible_type": "data_table"
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Scale of 5"
              },
              "description": "Student selected Scale of 5: assumes all numbers fit in range, missing that exact values require checking ones place digits",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "data_table_ec2",
                    "params": {
                      "highlight_categories": [
                        "Gus",
                        "Hal",
                        "Eli",
                        "Fay"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. Check the ones place digits: 3, 1, 9, 6. Are these multiples of 5? Only multiples of 5 end in 0 or 5."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Scale of 10"
              },
              "description": "Student selected Scale of 10: assumes larger scale always works, missing that exact values require checking ones place digits",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "data_table_ec2",
                    "params": {
                      "highlight_categories": [
                        "Gus",
                        "Hal",
                        "Eli",
                        "Fay"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Here's a hint: look at the ones place of each value. 23, 31, 9, 16. To show these exactly, your scale must count by a number that gets you to 3, 1, 9, and 6."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "data_table_ec2",
                    "params": {
                      "event": "highlight_ones_digits",
                      "status": "confirmed",
                      "description": "Ones place digits (3, 1, 9, 6) pulse to show they are not multiples of 5 or 10"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you how this works. The values are 23, 31, 9, 16. Look at the ones place: 3, 1, 9, 6. None end in 0 or 5, so they aren't multiples of 5 or 10. Scale of 2 counts by 2 and can show all these values exactly."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "data_table_ec2",
              "description": "Horizontal data table. Minutes Reading: Gus 23, Hal 31, Eli 9, Fay 16.",
              "tangible_type": "data_table"
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_ec3_select_appropriate_scale",
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "data_table_ec2",
          "params": {
            "description": "Previous data table clears."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "data_table_ec3",
          "tangible_type": "data_table",
          "params": {
            "description": "Vertical data table appears. Steps Walked: Ana 30, Ben 70, Cara 90, Dan 50."
          }
        },
        {
          "type": "dialogue",
          "text": "All these numbers end in 0. Think about the biggest number."
        },
        {
          "type": "prompt",
          "text": "Which scale is the best choice for this data?",
          "tool": "multiple_choice",
          "options": [
            "Scale of 10 — it's easiest to read.",
            "Scale of 5 — it shows more detail.",
            "Scale of 2 — it works for any numbers."
          ],
          "validator": [
            {
              "condition": {
                "selected": "Scale of 10 — it's easiest to read."
              },
              "description": "Student selected Scale of 10, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Scale of 10. For data up to 90, Scale of 10 gives you a clean graph with only 10 lines on the axis."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table_ec3",
                        "description": "Vertical data table. Steps Walked: Ana 30, Ben 70, Cara 90, Dan 50.",
                        "tangible_type": "data_table"
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Scale of 5 — it shows more detail."
              },
              "description": "Student selected Scale of 5: misconception that more detail is always better",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "data_table_ec3",
                    "params": {
                      "highlight_categories": [
                        "Ana",
                        "Ben",
                        "Cara",
                        "Dan"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're working on it. All the numbers end in 0, so Scale of 5 would create extra lines you don't need. Which scale matches these numbers best?"
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Scale of 2 — it works for any numbers."
              },
              "description": "Student selected Scale of 2: misconception that smallest scale is always appropriate",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "data_table_ec3",
                    "params": {
                      "highlight_categories": [
                        "Cara"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. To reach 90 with Scale of 2, you'd need 45 lines. That's too many. What scale fits these numbers better?"
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "data_table_ec3",
                    "params": {
                      "event": "highlight_pattern",
                      "status": "confirmed",
                      "description": "All values pulse briefly to show they end in 0"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Here, let me walk you through this one. Look at the numbers: 30, 70, 90, 50. They all end in 0. Scale of 10 matches perfectly. It gives you just 10 lines to reach 90."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "data_table_ec3",
              "description": "Vertical data table. Steps Walked: Ana 30, Ben 70, Cara 90, Dan 50.",
              "tangible_type": "data_table"
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_exit_check_closure",
    "type": "transition",
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "data_table_ec3",
          "params": {
            "description": "Final data table clears."
          }
        },
        {
          "type": "dialogue",
          "text": "You're ready to practice."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  }
]