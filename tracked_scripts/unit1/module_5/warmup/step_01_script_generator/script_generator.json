  {
    "id": "w2_scale_preview_exploration",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "data_table",
          "tangible_type": "data_table",
          "params": {
            "display_mode": "numeric",
            "categories": [
              "Red blocks",
              "Blue blocks",
              "Green blocks",
              "Yellow blocks"
            ],
            "values": [
              20,
              35,
              15,
              25
            ],
            "description": "Data table appears showing collected counts. Red blocks=20, Blue blocks=35, Green blocks=15, Yellow blocks=25."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "scale_preview_system",
          "tangible_type": "scale_selector",
          "params": {
            "available_scales": [
              1,
              2,
              5,
              10
            ],
            "preview_active": true,
            "description": "Scale Preview System appears with four clickable buttons: Scale of 1, Scale of 2, Scale of 5, Scale of 10. Preview pane ready to display bar graph."
          }
        },
        {
          "type": "dialogue",
          "text": "You know how to use different scales. But which one should you use for YOUR data?"
        },
        {
          "type": "dialogue",
          "text": "Let's find out. Click each scale to see what the graph would look like."
        },
        {
          "type": "prompt",
          "text": "Click each scale button to preview the graph.",
          "tool": "explore_scales",
          "target": "scale_preview_system",
          "validator": [
            {
              "condition": {
                "and": [
                  {
                    "explored": 1
                  },
                  {
                    "explored": 2
                  },
                  {
                    "explored": 5
                  },
                  {
                    "explored": 10
                  }
                ]
              },
              "description": "Student explored all four scales",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "All four scales work for this data! You have choices."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table",
                        "description": "Data table showing Red blocks=20, Blue blocks=35, Green blocks=15, Yellow blocks=25.",
                        "tangible_type": "data_table",
                        "display_mode": "numeric",
                        "categories": [
                          "Red blocks",
                          "Blue blocks",
                          "Green blocks",
                          "Yellow blocks"
                        ],
                        "values": [
                          20,
                          35,
                          15,
                          25
                        ]
                      },
                      {
                        "tangible_id": "scale_preview_system",
                        "description": "Scale Preview System with all four scales explored. Each scale marked as working for this data.",
                        "tangible_type": "scale_selector",
                        "available_scales": [
                          1,
                          2,
                          5,
                          10
                        ],
                        "preview_active": true
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "data_table",
              "description": "Data table showing collected counts. Red blocks=20, Blue blocks=35, Green blocks=15, Yellow blocks=25.",
              "tangible_type": "data_table",
              "display_mode": "numeric",
              "categories": [
                "Red blocks",
                "Blue blocks",
                "Green blocks",
                "Yellow blocks"
              ],
              "values": [
                20,
                35,
                15,
                25
              ]
            },
            {
              "tangible_id": "scale_preview_system",
              "description": "Scale Preview System with four clickable scale buttons. Preview pane ready. Exploration mode active.",
              "tangible_type": "scale_selector",
              "available_scales": [
                1,
