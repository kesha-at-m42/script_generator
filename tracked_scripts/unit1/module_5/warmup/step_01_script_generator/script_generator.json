[
  {
    "id": "w1_data_collection",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "minis_counting_scene",
          "tangible_type": "interactive_game",
          "params": {
            "game_type": "counting_sorting",
            "categories": [
              "Red blocks",
              "Blue blocks",
              "Green blocks",
              "Yellow blocks"
            ],
            "description": "Minis characters appear in animated warehouse scene with scattered colored blocks. Characters gesture toward piles of blocks waiting to be counted."
          }
        },
        {
          "type": "dialogue",
          "text": "The Minis are organizing their collections! Let's help them count."
        },
        {
          "type": "prompt",
          "text": "Count the blocks in each color and confirm your counts.",
          "tool": "counting_game",
          "target": "minis_counting_scene",
          "validator": [
            {
              "condition": {},
              "description": "Student completes counting game, any valid counts recorded",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "minis_counting_scene",
                    "params": {
                      "event": "record_counts",
                      "status": "confirmed",
                      "description": "Counted values appear on screen. Example: Red=20, Blue=35, Green=15, Yellow=25. Minis characters give thumbs up."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You counted them. Red has 20, Blue has 35, Green has 15, and Yellow has 25. Now let's make a graph with your data."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "minis_counting_scene",
                        "description": "Minis counting scene with confirmed counts displayed. Red=20, Blue=35, Green=15, Yellow=25. Characters celebrating completion.",
                        "tangible_type": "interactive_game",
                        "game_type": "counting_sorting",
                        "categories": [
                          "Red blocks",
                          "Blue blocks",
                          "Green blocks",
                          "Yellow blocks"
                        ]
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "minis_counting_scene",
              "description": "Minis characters in warehouse with colored blocks. Counting game active. Red, Blue, Green, Yellow categories visible.",
              "tangible_type": "interactive_game",
              "game_type": "counting_sorting",
              "categories": [
                "Red blocks",
                "Blue blocks",
                "Green blocks",
                "Yellow blocks"
              ]
            }
          ]
        }
      ]
    ]
