          "validator": [
            {
              "condition": {
                "selected": "Does the biggest number fit?"
              },
              "description": "Student selected checking fit first, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Right. Check if it fits first. That tells you which scales are even possible. Then check the digits."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table_stickers",
                        "description": "Data table showing Stickers Collected. Eli: 7, Fay: 12, Gus: 19, Hal: 23.",
                        "tangible_type": "data_table"
                      },
                      {
                        "tangible_id": "scale_preview_stickers",
                        "description": "Scale Preview System with Scale of 5 selected, showing warning state.",
                        "tangible_type": "scale_preview_system",
                        "selected_scale": 5,
                        "validation_state": "warning"
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Do the numbers end in 0 or 5?"
              },
              "description": "Student selected checking digits first instead of checking if biggest number fits",
