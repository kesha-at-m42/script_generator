          "params": {
            "selected_scale": 5,
            "validation_state": "error",
            "description": "Scale Preview System appears with Scale of 5 selected. Red X indicator shows 80 doesn't fit."
          }
        },
        {
          "type": "dialogue",
          "text": "Here's the first question you learned: Does the biggest number fit?"
        },
        {
          "type": "dialogue",
          "text": "Dan scored 80. That's too big for Scale of 5. You'd need a bigger scale."
        },
