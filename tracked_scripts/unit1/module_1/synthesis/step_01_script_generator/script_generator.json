[
  {
    "id": "s4_opening",
    "type": "transition",
    "scene": [],
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "You read picture graphs and bar graphs and used them to answer questions about the data. Now let's connect some ideas."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s4_1_representation_transfer",
    "scene": [],
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_sports",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 1,
            "categories": [
              "Soccer",
              "Basketball",
              "Baseball",
              "Tennis"
            ],
            "values": [
              7,
              5,
              4,
              6
            ],
            "title": "Favorite Sports",
            "key_visible": true,
            "description": "Horizontal picture graph appears on left side of screen. Favorite Sports data. Soccer=7, Basketball=5, Baseball=4, Tennis=6. Key shows each symbol = 1 vote."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_sports",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 1,
            "categories": [
              "Soccer",
              "Basketball",
              "Baseball",
              "Tennis"
            ],
            "values": [
              7,
              5,
              4,
              6
            ],
            "title": "Favorite Sports",
            "axis_range": [
              0,
              8
            ],
            "axis_labels_visible": true,
            "description": "Vertical bar graph appears on right side of screen. Same Favorite Sports data as picture graph. Soccer=7, Basketball=5, Baseball=4, Tennis=6. Axis shows 0-8."
          }
        },
        {
          "type": "dialogue",
          "text": "Look at these two graphs. They show the same data. What's the same about both graphs?"
        },
        {
          "type": "prompt",
          "text": "What's the same about both graphs? Select all that apply.",
          "tool": "multi_select",
          "options": [
            "They have the same title",
            "They show the same categories",
            "Soccer has the most in both",
            "They look exactly the same"
          ],
          "validator": [
            {
              "condition": {
                "and": [
                  {
                    "selected": "They have the same title"
                  },
                  {
                    "selected": "They show the same categories"
                  },
                  {
                    "selected": "Soccer has the most in both"
                  },
                  {
                    "not_selected": "They look exactly the same"
                  }
                ]
              },
              "description": "Student selected first three options correctly — same title, same categories, same data. Did not select 'look exactly the same'",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "The information is the same. The format is different. Picture graphs use symbols. Bar graphs use bars. Both show the same data — you can read either one."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "picture_graph_sports",
                        "description": "Horizontal picture graph on left. Favorite Sports data. Soccer=7 highlighted as highest.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "categories": [
                          "Soccer",
                          "Basketball",
                          "Baseball",
                          "Tennis"
                        ]
                      },
                      {
                        "tangible_id": "bar_graph_sports",
                        "description": "Vertical bar graph on right. Same Favorite Sports data. Soccer bar highlighted as tallest.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "categories": [
                          "Soccer",
                          "Basketball",
                          "Baseball",
                          "Tennis"
                        ]
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "picture_graph_sports",
              "description": "Horizontal picture graph on left side. Favorite Sports data. Soccer=7, Basketball=5, Baseball=4, Tennis=6. Key visible. multi_select tool active.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "categories": [
                "Soccer",
                "Basketball",
                "Baseball",
                "Tennis"
              ]
            },
            {
              "tangible_id": "bar_graph_sports",
              "description": "Vertical bar graph on right side. Same Favorite Sports data as picture graph. Axis 0-8 visible. multi_select tool active.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "categories": [
                "Soccer",
                "Basketball",
                "Baseball",
                "Tennis"
              ]
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s4_2_pattern_discovery",
    "scene": [],
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_pets",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 1,
            "categories": [
              "Dogs",
              "Cats",
              "Fish",
              "Birds"
            ],
            "values": [
              5,
              4,
              3,
              6
            ],
            "title": "Favorite Pets",
            "key_visible": true,
            "component_labels": {
              "A": "title",
              "B": "key",
              "C": "category_labels"
            },
            "description": "Horizontal picture graph appears. Favorite Pets data. Dogs=5, Cats=4, Fish=3, Birds=6. Three components labeled by system overlay: A=Title 'Favorite Pets', B=Key 'Each ★ = 1 vote', C=Category labels (Dogs, Cats, Fish, Birds). Labels are clickable."
          }
        },
        {
          "type": "dialogue",
          "text": "Every part of a graph has a job. This picture graph has three parts labeled A, B, and C. Click on the part that shows what each symbol means."
        },
        {
          "type": "prompt",
          "text": "Which part tells you what each symbol means?",
          "tool": "click_component",
          "target": "picture_graph_pets.component",
          "validator": [
            {
              "condition": {
                "selected": "B"
              },
              "description": "Student clicked component B — the key — correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "picture_graph_pets",
                    "params": {
                      "event": "highlight_component",
                      "component": "B",
                      "status": "confirmed",
                      "description": "Component B (the key) highlights with glow effect"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "The key tells you what each symbol means. Here, each star equals 1 vote. Title tells what the graph is about. Labels name the categories. Key shows the scale. Every part has a job."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "picture_graph_pets",
                        "description": "Horizontal picture graph. Favorite Pets data. Component B (key) highlighted showing 'Each ★ = 1 vote'.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "categories": [
                          "Dogs",
                          "Cats",
                          "Fish",
                          "Birds"
                        ]
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "picture_graph_pets",
              "description": "Horizontal picture graph. Favorite Pets data. Three labeled components visible: A=Title, B=Key, C=Category labels. click_component tool active.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "categories": [
                "Dogs",
                "Cats",
                "Fish",
                "Birds"
              ]
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s4_3_real_world_bridge",
    "scene": [],
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "Graphs aren't just in math class. People use them everywhere. Look at these three scenarios. Which of these could use a bar graph to show the data?"
        },
        {
          "type": "prompt",
          "text": "Which of these could use a bar graph to show the data? Select all that apply.",
          "tool": "multi_select",
          "options": [
            "Your class votes on a field trip destination",
            "Library tracks which book genre students check out most",
            "Cafeteria tracks which lunch is most popular"
          ],
          "validator": [
            {
              "condition": {
                "and": [
                  {
                    "selected": "Your class votes on a field trip destination"
                  },
                  {
                    "selected": "Library tracks which book genre students check out most"
                  },
                  {
                    "selected": "Cafeteria tracks which lunch is most popular"
                  }
                ]
              },
              "description": "Student selected all three scenarios — all are categorical data that could use bar graphs",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "All of them! Any time you're counting and comparing categories, a graph can help. Graphs help people see patterns and make decisions. You'll see them in school, in stores, on the news — everywhere."
                  },
                  {
                    "type": "current_scene",
                    "elements": []
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s4_4_metacognitive_reflection",
    "scene": [],
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "You saw two kinds of comparison questions today. To answer both questions, what do you need to do?"
        },
        {
          "type": "prompt",
          "text": "To answer both questions, what do you need to do?",
          "tool": "multiple_choice",
          "options": [
            "Add the categories",
            "Subtract the categories",
            "Find each value"
          ],
          "validator": [
            {
              "condition": {
                "selected": "Subtract the categories"
              },
              "description": "Student answered subtract — correct, both 'how many more' and 'how many fewer' require subtraction",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "'How many more' and 'how many fewer' — both mean subtract. You find the difference to compare."
                  },
                  {
                    "type": "current_scene",
                    "elements": []
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s4_closure",
    "type": "transition",
    "scene": [],
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_warmup_review",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 1,
            "categories": [
              "Category A",
              "Category B",
              "Category C"
            ],
            "description": "Student's Warmup graph reappears on left — horizontal picture graph with 3 categories they created earlier"
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_lesson_review",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 1,
            "categories": [
              "Dogs",
              "Cats",
              "Fish",
              "Birds"
            ],
            "description": "A Lesson graph from earlier sections appears on right — horizontal picture graph showing data they read during the lesson"
          }
        },
        {
          "type": "dialogue",
          "text": "You made your own graph. You read other people's graphs. You answered comparison questions and found totals. You know how to collect and represent data."
        },
        {
          "type": "dialogue",
          "text": "Next time, you'll see graphs where each symbol means more than one. Get ready for a new challenge."
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "picture_graph_warmup_review",
              "description": "Student's Warmup graph displayed on left side — horizontal picture graph with 3 categories they created",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal"
            },
            {
              "tangible_id": "picture_graph_lesson_review",
              "description": "Lesson graph displayed on right side — horizontal picture graph from earlier sections",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal"
            }
          ]
        }
      ]
    ]
  }
]