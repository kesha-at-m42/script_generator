[
  {
    "id": "s4_opening",
    "type": "transition",
    "scene": [],
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "You read picture graphs and bar graphs and used them to answer questions about the data. Now let's connect some ideas."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s4_1_representation_transfer",
    "scene": [],
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "picture_graph_sports",
          "tangible_type": "picture_graph",
          "params": {
            "mode": "reading",
            "orientation": "horizontal",
            "scale": 1,
            "categories": [
              "Soccer",
              "Basketball",
              "Baseball",
              "Tennis"
            ],
            "values": [
              7,
              5,
              4,
              6
            ],
            "title": "Favorite Sports",
            "key_visible": true,
            "description": "Horizontal picture graph appears on left side of screen. Favorite Sports data. Soccer=7, Basketball=5, Baseball=4, Tennis=6. Key shows each symbol = 1 vote."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_sports",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 1,
            "categories": [
              "Soccer",
              "Basketball",
              "Baseball",
              "Tennis"
            ],
            "values": [
              7,
              5,
              4,
              6
            ],
            "title": "Favorite Sports",
            "axis_range": [
              0,
              8
            ],
            "axis_labels_visible": true,
            "description": "Vertical bar graph appears on right side of screen. Same Favorite Sports data as picture graph. Soccer=7, Basketball=5, Baseball=4, Tennis=6. Axis shows 0-8."
          }
        },
        {
          "type": "dialogue",
          "text": "Look at these two graphs. They show the same data. What's the same about both graphs?"
        },
        {
          "type": "prompt",
          "text": "What's the same about both graphs? Select all that apply.",
          "tool": "multi_select",
          "options": [
            "They have the same title",
            "They show the same categories",
            "Soccer has the most in both",
            "They look exactly the same"
          ],
          "validator": [
            {
              "condition": {
                "and": [
                  {
                    "selected": "They have the same title"
                  },
                  {
                    "selected": "They show the same categories"
                  },
                  {
                    "selected": "Soccer has the most in both"
                  },
                  {
                    "not_selected": "They look exactly the same"
                  }
                ]
              },
              "description": "Student selected first three options correctly — same title, same categories, same data. Did not select 'look exactly the same'",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "The information is the same. The format is different. Picture graphs use symbols. Bar graphs use bars. Both show the same data — you can read either one."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "picture_graph_sports",
                        "description": "Horizontal picture graph on left. Favorite Sports data. Soccer=7 highlighted as highest.",
                        "tangible_type": "picture_graph",
                        "mode": "reading",
                        "orientation": "horizontal",
                        "categories": [
                          "Soccer",
                          "Basketball",
                          "Baseball",
                          "Tennis"
                        ]
                      },
                      {
                        "tangible_id": "bar_graph_sports",
                        "description": "Vertical bar graph on right. Same Favorite Sports data. Soccer bar highlighted as tallest.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "categories": [
                          "Soccer",
                          "Basketball",
                          "Baseball",
                          "Tennis"
                        ]
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "and": [
                  {
                    "or": [
                      {
                        "selected": "They have the same title"
                      },
                      {
                        "selected": "They show the same categories"
                      },
                      {
                        "selected": "Soccer has the most in both"
                      }
                    ]
                  },
                  {
                    "not": {
                      "and": [
                        {
                          "selected": "They have the same title"
                        },
                        {
                          "selected": "They show the same categories"
                        },
                        {
                          "selected": "Soccer has the most in both"
                        }
                      ]
                    }
                  },
                  {
                    "not_selected": "They look exactly the same"
                  }
                ]
              },
              "description": "Branch 2: Student selected only correct answers, but not all three. Under-selecting.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_sports",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_sports",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're getting there. Everything you picked is true. Look at both graphs again. Are there other things that are the same?"
                  }
                ]
              ]
            },
            {
              "condition": {
                "and": [
                  {
                    "not": {
                      "or": [
                        {
                          "selected": "They have the same title"
                        },
                        {
                          "selected": "They show the same categories"
                        },
                        {
                          "selected": "Soccer has the most in both"
                        }
                      ]
                    }
                  }
                ]
              },
              "description": "Branch 3: Student selected only incorrect answers. All-wrong.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "picture_graph_sports",
                    "params": {
                      "event": "pulse_title",
                      "status": "proposed",
                      "description": "Picture graph title pulses briefly"
                    }
                  },
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "bar_graph_sports",
                    "params": {
                      "event": "pulse_title",
                      "status": "proposed",
                      "description": "Bar graph title pulses briefly"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about what makes these graphs show the same information. Look at the titles, the categories, and what the data tells you. What stays the same when we change the format?"
                  }
                ]
              ]
            },
            {
              "condition": {
                "and": [
                  {
                    "selected": "They look exactly the same"
                  },
                  {
                    "or": [
                      {
                        "selected": "They have the same title"
                      },
                      {
                        "selected": "They show the same categories"
                      },
                      {
                        "selected": "Soccer has the most in both"
                      }
                    ]
                  }
                ]
              },
              "description": "Branch 4: Student selected mix of correct and incorrect. Over-selecting with 'look exactly the same'.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_sports",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_sports",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You found some things that are the same. The information matches. But look closely at how each graph shows the data. Do they look exactly the same, or is the format different?"
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "picture_graph_sports",
                    "params": {
                      "event": "highlight_title_and_categories",
                      "status": "confirmed",
                      "description": "Picture graph title and category labels highlight in sequence"
                    }
                  },
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "bar_graph_sports",
                    "params": {
                      "event": "highlight_title_and_categories",
                      "status": "confirmed",
                      "description": "Bar graph title and category labels highlight in sequence, matching picture graph timing"
                    }
                  },
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_sports",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_sports",
                    "params": {
                      "highlight_categories": [
                        "Soccer"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you. Both graphs have the same title: Favorite Sports. Both show the same four sports. And Soccer has the most votes in both. The data is the same. Only the format is different."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "picture_graph_sports",
              "description": "Horizontal picture graph on left side. Favorite Sports data. Soccer=7, Basketball=5, Baseball=4, Tennis=6. Key visible. multi_select tool active.",
              "tangible_type": "picture_graph",
              "mode": "reading",
              "orientation": "horizontal",
              "categories": [
                "Soccer",
                "Basketball",
                "Baseball",
                "Tennis"
              ]
            },
            {
              "tangible_id": "bar_graph_sports",
              "description": "Vertical bar graph on right side. Same Favorite Sports data as picture graph. Axis 0-8 visible. multi_select tool active.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "categories": [
                "Soccer",
                "Basketball",
                "Baseball",
                "Tennis"
              ]
            }
          ]
        }
      ]
    ]
