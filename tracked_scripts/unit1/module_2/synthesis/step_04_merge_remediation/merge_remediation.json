              "description": "Student selected '2 items' — confusing half-symbol with full symbol",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_numbers",
                    "params": {
                      "highlight_categories": []
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're working on it. A full symbol shows 2 items. A half-symbol shows half of that—what's half of 2?"
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Nothing—it's decoration"
              },
              "description": "Student selected 'Nothing—it's decoration' — misunderstanding that half-symbols have meaning",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_numbers",
                    "params": {
                      "highlight_categories": []
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. Every symbol has meaning. If each full symbol = 2, then half of it shows half of 2."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly — system models the correct answer",
              "is_correct": false,
              "steps": [
