                    "type": "dialogue",
                    "text": "8 splits evenly into groups of 2—no leftover 1. Only odd numbers need a half-symbol."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "12"
              },
              "description": "Student selected 12 — an even number that doesn't need a half-symbol",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_numbers",
                    "params": {
                      "highlight_categories": [
                        "12"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "12 splits evenly into groups of 2—no leftover. Only odd numbers need a half-symbol for the extra 1."
