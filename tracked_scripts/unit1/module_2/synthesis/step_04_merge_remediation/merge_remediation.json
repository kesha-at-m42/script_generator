              "description": "Student selected 'Half of the total' — confusing scale value with total count",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "picture_graph_numbers",
                    "params": {
                      "highlight_categories": []
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Here's a hint: The key says each symbol = 2. A half-symbol shows half of that scale value, not half of everything."
