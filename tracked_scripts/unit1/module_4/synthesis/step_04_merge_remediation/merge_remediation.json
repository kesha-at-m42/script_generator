[
  {
    "id": "s1_opening_frame",
    "type": "transition",
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "You read and created bar graphs with scale of 10. You figured out values at the lines AND between the lines. Let's look at some patterns you discovered."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s1_1_scale_progression",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_scale_1",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 1,
            "categories": [
              "Amount"
            ],
            "values": [
              20
            ],
            "axis_range": [
              0,
              20
            ],
            "description": "Vertical bar graph with scale of 1. Single bar reaching 20. Axis shows 0, 1, 2, 3... up to 20. Twenty tick marks visible."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_scale_2",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 2,
            "categories": [
              "Amount"
            ],
            "values": [
              20
            ],
            "axis_range": [
              0,
              20
            ],
            "description": "Vertical bar graph with scale of 2. Single bar reaching 20. Axis shows 0, 2, 4, 6... up to 20. Ten tick marks visible."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_scale_5",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 5,
            "categories": [
              "Amount"
            ],
            "values": [
              20
            ],
            "axis_range": [
              0,
              20
            ],
            "description": "Vertical bar graph with scale of 5. Single bar reaching 20. Axis shows 0, 5, 10, 15, 20. Four tick marks visible."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_scale_10",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 10,
            "categories": [
              "Amount"
            ],
            "values": [
              20
            ],
            "axis_range": [
              0,
              20
            ],
            "description": "Vertical bar graph with scale of 10. Single bar reaching 20. Axis shows 0, 10, 20. Two tick marks visible."
          }
        },
        {
          "type": "dialogue",
          "text": "Look at all four graphs. They show the same amount, 20. Which scale uses the fewest lines to show the same amount?"
        },
        {
          "type": "prompt",
          "text": "Click on the graph with the scale that uses the fewest lines.",
          "tool": {
            "name": "click_tangible",
            "target": [
              "bar_graph_scale_1",
              "bar_graph_scale_2",
              "bar_graph_scale_5",
              "bar_graph_scale_10"
            ]
          },
          "validator": [
            {
              "condition": {
                "selected": "bar_graph_scale_10"
              },
              "description": "Student clicked scale of 10 graph, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "bar_graph_scale_10",
                    "params": {
                      "event": "highlight_graph",
                      "status": "confirmed",
                      "description": "Scale of 10 graph highlights to confirm selection."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Scale of 10 uses the fewest lines. Each line shows more, so you need fewer of them."
                  },
                  {
                    "type": "dialogue",
                    "text": "You've learned four scales now: 1, 2, 5, and 10. Each one is useful for different sized numbers. Bigger numbers work better with bigger scales."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "bar_graph_scale_1",
                        "description": "Vertical bar graph with scale of 1. Single bar at 20. Twenty tick marks.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 1,
                        "categories": [
                          "Amount"
                        ],
                        "values": [
                          20
                        ]
                      },
                      {
                        "tangible_id": "bar_graph_scale_2",
                        "description": "Vertical bar graph with scale of 2. Single bar at 20. Ten tick marks.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 2,
                        "categories": [
                          "Amount"
                        ],
                        "values": [
                          20
                        ]
                      },
                      {
                        "tangible_id": "bar_graph_scale_5",
                        "description": "Vertical bar graph with scale of 5. Single bar at 20. Four tick marks.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 5,
                        "categories": [
                          "Amount"
                        ],
                        "values": [
                          20
                        ]
                      },
                      {
                        "tangible_id": "bar_graph_scale_10",
                        "description": "Vertical bar graph with scale of 10 highlighted. Single bar at 20. Two tick marks.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 10,
                        "categories": [
                          "Amount"
                        ],
                        "values": [
                          20
                        ]
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "incorrect_count": 1
              },
              "description": "Student clicked a wrong graph on first attempt",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "Not quite. Count the lines on each graph's axis."
                  }
                ]
              ]
            },
            {
              "condition": {
                "incorrect_count": 2
              },
              "description": "Student clicked a wrong graph on second attempt",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_scale_10",
                    "params": {
                      "highlight_categories": [
                        "Amount"
                      ]
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. The scale of 1 has 20 lines. The scale of 10 has only 2 lines."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student clicked a wrong graph three or more times. System models the answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "bar_graph_scale_10",
                    "params": {
                      "event": "highlight_graph",
                      "status": "confirmed",
                      "description": "Scale of 10 graph highlights. Tick marks at 0, 10, 20 pulse to show only 2 lines needed."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you how this works. The scale of 10 uses the fewest lines. Count them: 0, 10, 20. That's just 2 tick marks to show 20. The other graphs need more lines because their scales are smaller."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar_graph_scale_1",
              "description": "Vertical bar graph with scale of 1. Single bar reaching 20. Twenty tick marks on axis.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 1,
              "categories": [
                "Amount"
              ],
              "values": [
                20
              ]
            },
            {
              "tangible_id": "bar_graph_scale_2",
              "description": "Vertical bar graph with scale of 2. Single bar reaching 20. Ten tick marks on axis.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 2,
              "categories": [
                "Amount"
              ],
              "values": [
                20
              ]
            },
            {
              "tangible_id": "bar_graph_scale_5",
              "description": "Vertical bar graph with scale of 5. Single bar reaching 20. Four tick marks on axis.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 5,
              "categories": [
                "Amount"
              ],
              "values": [
                20
              ]
            },
            {
              "tangible_id": "bar_graph_scale_10",
              "description": "Vertical bar graph with scale of 10. Single bar reaching 20. Two tick marks on axis.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 10,
              "categories": [
                "Amount"
              ],
              "values": [
                20
              ]
            }
          ]
        }
      ]
    ]
  },
  {
