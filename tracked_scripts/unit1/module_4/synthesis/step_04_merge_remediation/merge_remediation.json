  {
    "id": "s1_3_real_world_connection",
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "bar_graph_vertical"
        },
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "bar_graph_horizontal"
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "image_money",
          "tangible_type": "image",
          "params": {
            "description": "Image showing stacks of 10 dollar bills arranged in groups."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "image_ruler",
          "tangible_type": "image",
          "params": {
            "description": "Image showing a ruler marked in tens of centimeters."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "image_counting_one",
          "tangible_type": "image",
          "params": {
            "description": "Image showing items being counted one by one individually."
          }
        },
        {
          "type": "dialogue",
          "text": "Scale of 10 is useful when numbers are bigger. Where might you see counting by tens outside of math class?"
        },
        {
          "type": "prompt",
          "text": "Which situations would work well with a scale of 10? Select all that apply.",
          "tool": {
            "name": "multi_select",
            "options": [
              "Counting money (stacks of 10 dollar bills)",
              "Measuring height (ruler marked in 10s of centimeters)",
              "Counting items one by one"
            ]
          },
          "validator": [
            {
              "condition": {
                "and": [
                  {
                    "selected": "Counting money (stacks of 10 dollar bills)"
                  },
                  {
                    "selected": "Measuring height (ruler marked in 10s of centimeters)"
                  }
                ]
              },
              "description": "Student selected money and ruler, both correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_money",
                    "params": {
                      "event": "highlight_image",
                      "status": "confirmed",
                      "description": "Money image highlights as a correct selection."
                    }
                  },
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_ruler",
                    "params": {
                      "event": "highlight_image",
                      "status": "confirmed",
                      "description": "Ruler image highlights as a correct selection."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Money and measuring often use tens. That's why scale of 10 feels natural for bigger amounts."
                  },
                  {
                    "type": "dialogue",
                    "text": "You already know how to count by tens. Bar graphs use the same skill you use with money and measuring."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "image_money",
                        "description": "Image of money stacks highlighted as correct selection.",
                        "tangible_type": "image"
                      },
                      {
                        "tangible_id": "image_ruler",
                        "description": "Image of ruler highlighted as correct selection.",
                        "tangible_type": "image"
                      },
                      {
                        "tangible_id": "image_counting_one",
                        "description": "Image of individual counting, not highlighted.",
                        "tangible_type": "image"
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": "Counting items one by one"
              },
              "description": "Student selected 'Counting items one by one', which does not benefit from scale of 10",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_counting_one",
                    "params": {
                      "event": "highlight_image",
                      "status": "error",
                      "description": "Individual counting image highlights to show why this doesn't need scale of 10."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. Counting items one by one works fine without grouping by tens. Where would grouping by tens actually help?"
                  }
                ]
              ]
            },
            {
              "condition": {
                "incorrect_count": 1
              },
              "description": "Student selected at least one wrong option or missed a correct option on first attempt",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_money",
                    "params": {
                      "event": "pulse_image",
                      "status": "proposed",
                      "description": "Money image pulses to draw attention to grouping by tens."
                    }
                  },
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_ruler",
                    "params": {
                      "event": "pulse_image",
                      "status": "proposed",
                      "description": "Ruler image pulses to draw attention to marks in tens."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Here's a hint: think about situations where you naturally group things by tens or skip count by tens."
                  }
                ]
              ]
            },
            {
              "condition": {
                "incorrect_count": 2
              },
              "description": "Student selected at least one wrong option or missed a correct option on second attempt",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_money",
                    "params": {
                      "event": "highlight_image",
                      "status": "proposed",
                      "description": "Money image highlights showing stacks organized by tens."
                    }
                  },
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_ruler",
                    "params": {
                      "event": "highlight_image",
                      "status": "proposed",
                      "description": "Ruler image highlights showing measurement marks in tens."
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're working on it. Money comes in stacks of tens. Rulers have marks at 10, 20, 30. Both use scale of 10 because the numbers are bigger."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly three or more times. System models the answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "image_money",
                    "params": {
                      "event": "highlight_image",
                      "status": "confirmed",
                      "description": "Money image highlights as system demonstrates correct answer."
                    }
                  },
