[
  {
    "id": "s1_transition_to_exit_check",
    "type": "transition",
    "steps": [
      [
        {
          "type": "dialogue",
          "text": "You made bar graphs with scale of 10. You read values at the lines and between the lines. Let's see what you know."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  },
  {
    "id": "s1_ec1_read_at_line",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_books",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 10,
            "axis_range": [
              0,
              60
            ],
            "categories": [
              "Nonfiction",
              "Fiction",
              "Comics",
              "Poetry"
            ],
            "values": [
              30,
              40,
              50,
              20
            ],
            "description": "Vertical bar graph appears. Books Checked Out. Nonfiction=30, Fiction=40, Comics=50, Poetry=20. Scale of 10, axis 0 to 60. All bars end at axis lines."
          }
        },
        {
          "type": "dialogue",
          "text": "Look at the Fiction bar. What value does the Fiction bar show?"
        },
        {
          "type": "prompt",
          "text": "What value does the Fiction bar show?",
          "tool": "multiple_choice",
          "options": [
            4,
            35,
            40,
            45
          ],
          "validator": [
            {
              "condition": {
                "selected": 40
              },
              "description": "Student selected 40, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "40. The bar ends right at the 40 line on the axis."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "bar_graph_books",
                        "description": "Vertical bar graph. Books Checked Out. Fiction bar at 40.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 10,
                        "axis_range": [
                          0,
                          60
                        ],
                        "categories": [
                          "Nonfiction",
                          "Fiction",
                          "Comics",
                          "Poetry"
                        ],
                        "values": [
                          30,
                          40,
                          50,
                          20
                        ]
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar_graph_books",
              "description": "Vertical bar graph. Books Checked Out. Nonfiction=30, Fiction=40, Comics=50, Poetry=20. Scale of 10, axis 0 to 60.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 10,
              "axis_range": [
                0,
                60
              ],
              "categories": [
                "Nonfiction",
                "Fiction",
                "Comics",
                "Poetry"
              ],
              "values": [
                30,
                40,
                50,
                20
              ]
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_ec2_read_between_lines",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_points",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "reading",
            "orientation": "vertical",
            "scale": 10,
            "axis_range": [
              0,
              60
            ],
            "categories": [
              "Team A",
              "Team B",
              "Team C",
              "Team D"
            ],
            "values": [
              35,
              50,
              25,
              40
            ],
            "ghost_gridlines": true,
            "description": "Vertical bar graph appears. Points Earned. Team A=35, Team B=50, Team C=25, Team D=40. Scale of 10, axis 0 to 60. Ghost gridlines at 5s visible."
          }
        },
        {
          "type": "dialogue",
          "text": "Look at Team A's bar. It ends between the lines. The bar is between 30 and 40. What value does this show?"
        },
        {
          "type": "prompt",
          "text": "What is the value represented for Team A?",
          "tool": "multiple_choice",
          "options": [
            30,
            34,
            35,
            40
          ],
          "validator": [
            {
              "condition": {
                "selected": 35
              },
              "description": "Student selected 35, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "35. It's halfway between 30 and 40. Half of 10 is 5."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "bar_graph_points",
                        "description": "Vertical bar graph. Points Earned. Team A=35, between 30 and 40 lines. Ghost gridlines visible.",
                        "tangible_type": "bar_graph",
                        "mode": "reading",
                        "orientation": "vertical",
                        "scale": 10,
                        "axis_range": [
                          0,
                          60
                        ],
                        "categories": [
                          "Team A",
                          "Team B",
                          "Team C",
                          "Team D"
                        ],
                        "values": [
                          35,
                          50,
                          25,
                          40
                        ],
                        "ghost_gridlines": true
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar_graph_points",
              "description": "Vertical bar graph. Points Earned. Team A=35, Team B=50, Team C=25, Team D=40. Scale of 10, axis 0 to 60. Ghost gridlines at 5s visible.",
              "tangible_type": "bar_graph",
              "mode": "reading",
              "orientation": "vertical",
              "scale": 10,
              "axis_range": [
                0,
                60
              ],
              "categories": [
                "Team A",
                "Team B",
                "Team C",
                "Team D"
              ],
              "values": [
                35,
                50,
                25,
                40
              ],
              "ghost_gridlines": true
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_ec3_create_mixed_values",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "data_table_supplies",
          "tangible_type": "data_table",
          "params": {
            "display_mode": "numeric",
            "orientation": "horizontal",
            "categories": [
              "Markers",
              "Crayons",
              "Paintbrushes",
              "Glue Sticks"
            ],
            "values": [
              30,
              45,
              20,
              55
            ],
            "description": "Horizontal data table appears. Art Supplies Collected. Markers=30, Crayons=45, Paintbrushes=20, Glue Sticks=55."
          }
        },
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "bar_graph_supplies",
          "tangible_type": "bar_graph",
          "params": {
            "mode": "creating",
            "orientation": "vertical",
            "scale": 10,
            "axis_range": [
              0,
              60
            ],
            "categories": [
              "Markers",
              "Crayons",
              "Paintbrushes",
              "Glue Sticks"
            ],
            "bar_heights": [
              0,
              0,
              0,
              0
            ],
            "ghost_gridlines": true,
            "snap_to_valid_values": true,
            "snap_increment": 5,
            "description": "Vertical bar graph appears in creating mode. Art Supplies Collected. Scale of 10, axis 0 to 60. No bars filled. Ghost gridlines at 5s visible. Click-to-set active."
          }
        },
        {
          "type": "dialogue",
          "text": "Create the bar graph. Some values are at the lines, some are between."
        },
        {
          "type": "prompt",
          "text": "Complete the graph.",
          "tool": "click_to_set_bars",
          "target": "bar_graph_supplies",
          "validator": [
            {
              "condition": {
                "and": [
                  {
                    "bar": "Markers",
                    "height": 30
                  },
                  {
                    "bar": "Crayons",
                    "height": 45
                  },
                  {
                    "bar": "Paintbrushes",
                    "height": 20
                  },
                  {
                    "bar": "Glue Sticks",
                    "height": 55
                  }
                ]
              },
              "description": "Student set all four bars correctly",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "update",
                    "tangible_id": "bar_graph_supplies",
                    "params": {
                      "bar_heights": [
                        30,
                        45,
                        20,
                        55
                      ],
                      "mode": "confirmed"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Markers and Paintbrushes at the lines. Crayons and Glue Sticks between the lines. You placed all four correctly."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "data_table_supplies",
                        "description": "Horizontal data table. Art Supplies Collected. Markers=30, Crayons=45, Paintbrushes=20, Glue Sticks=55.",
                        "tangible_type": "data_table",
                        "display_mode": "numeric",
                        "orientation": "horizontal",
                        "categories": [
                          "Markers",
                          "Crayons",
                          "Paintbrushes",
                          "Glue Sticks"
                        ],
                        "values": [
                          30,
                          45,
                          20,
                          55
                        ]
                      },
                      {
                        "tangible_id": "bar_graph_supplies",
                        "description": "Vertical bar graph. Art Supplies Collected. All bars set. Markers=30, Crayons=45, Paintbrushes=20, Glue Sticks=55.",
                        "tangible_type": "bar_graph",
                        "mode": "confirmed",
                        "orientation": "vertical",
                        "scale": 10,
                        "axis_range": [
                          0,
                          60
                        ],
                        "categories": [
                          "Markers",
                          "Crayons",
                          "Paintbrushes",
                          "Glue Sticks"
                        ],
                        "bar_heights": [
                          30,
                          45,
                          20,
                          55
                        ],
                        "ghost_gridlines": true
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "data_table_supplies",
              "description": "Horizontal data table. Art Supplies Collected. Markers=30, Crayons=45, Paintbrushes=20, Glue Sticks=55.",
              "tangible_type": "data_table",
              "display_mode": "numeric",
              "orientation": "horizontal",
              "categories": [
                "Markers",
                "Crayons",
                "Paintbrushes",
                "Glue Sticks"
              ],
              "values": [
                30,
                45,
                20,
                55
              ]
            },
            {
              "tangible_id": "bar_graph_supplies",
              "description": "Vertical bar graph in creating mode. Art Supplies Collected. Scale of 10, axis 0 to 60. No bars filled yet. Ghost gridlines at 5s visible.",
              "tangible_type": "bar_graph",
              "mode": "creating",
              "orientation": "vertical",
              "scale": 10,
              "axis_range": [
                0,
                60
              ],
              "categories": [
                "Markers",
                "Crayons",
                "Paintbrushes",
                "Glue Sticks"
              ],
              "bar_heights": [
                0,
                0,
                0,
                0
              ],
              "ghost_gridlines": true,
              "snap_to_valid_values": true
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_ec4_comparison_problem",
    "steps": [
      [
        {
          "type": "scene",
          "method": "hide",
          "tangible_id": "data_table_supplies"
        },
        {
          "type": "dialogue",
          "text": "Use the graph you made. How many more art supplies does Glue Sticks have than Markers?"
        },
        {
          "type": "prompt",
          "text": "How many MORE art supplies does Glue Sticks have than Markers?",
          "tool": "multiple_choice",
          "options": [
            15,
            25,
            55,
            85
          ],
          "validator": [
            {
              "condition": {
                "selected": 25
              },
              "description": "Student selected 25, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "dialogue",
                    "text": "25 more. Glue Sticks has 55, Markers has 30. The difference is 25."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "bar_graph_supplies",
                        "description": "Vertical bar graph. Art Supplies Collected. Markers=30, Crayons=45, Paintbrushes=20, Glue Sticks=55.",
                        "tangible_type": "bar_graph",
                        "mode": "confirmed",
                        "orientation": "vertical",
                        "scale": 10,
                        "axis_range": [
                          0,
                          60
                        ],
                        "categories": [
                          "Markers",
                          "Crayons",
                          "Paintbrushes",
                          "Glue Sticks"
                        ],
                        "bar_heights": [
                          30,
                          45,
                          20,
                          55
                        ],
                        "ghost_gridlines": true
                      }
                    ]
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "bar_graph_supplies",
              "description": "Vertical bar graph. Art Supplies Collected. Markers=30, Crayons=45, Paintbrushes=20, Glue Sticks=55. Data table hidden.",
              "tangible_type": "bar_graph",
              "mode": "confirmed",
              "orientation": "vertical",
              "scale": 10,
              "axis_range": [
                0,
                60
              ],
              "categories": [
                "Markers",
                "Crayons",
                "Paintbrushes",
                "Glue Sticks"
              ],
              "bar_heights": [
                30,
                45,
                20,
                55
              ],
              "ghost_gridlines": true
            }
          ]
        }
      ]
    ]
  },
  {
    "id": "s1_exit_check_closure",
    "type": "transition",
    "steps": [
      [
        {
          "type": "scene",
          "method": "remove",
          "tangible_id": "bar_graph_supplies"
        },
        {
          "type": "dialogue",
          "text": "You can read bar graphs with scale of 10, even values between the lines. You're ready to practice."
        },
        {
          "type": "current_scene",
          "elements": []
        }
      ]
    ]
  }
]