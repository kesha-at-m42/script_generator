            "orientation": "vertical",
            "scale": 10,
            "categories": [
              "Red",
              "Blue",
              "Yellow"
            ],
            "values": [
              40,
              20,
              60
            ],
            "axis_range": [
              0,
              10,
              20,
              30,
              40,
              50,
              60
            ],
            "description": "Vertical bar graph appears on right. Scale of 10. Axis shows 0, 10, 20, 30, 40, 50, 60. Red bar reaches 40, Blue bar reaches 20, Yellow bar reaches 60."
          }
