[
  {
    "id": "w1_data_collection",
    "steps": [
      [
        {
          "type": "scene",
          "method": "add",
          "tangible_id": "minis_counting_scene",
          "tangible_type": "counting_game",
          "params": {
            "categories": [
              "Red",
              "Blue",
              "Yellow"
            ],
            "target_values": [
              40,
              20,
              60
            ],
            "description": "Animated Minis scene appears. Three groups of items visible: Red items (40), Blue items (20), Yellow items (60). Minis characters animated collecting items in each category."
          }
        },
        {
          "type": "dialogue",
          "text": "The Minis are collecting items! Help count what they found."
        },
        {
          "type": "prompt",
          "text": "How many RED items did the Minis collect?",
          "tool": "multiple_choice",
          "options": [
            30,
            40,
            50,
            60
          ],
          "validator": [
            {
              "condition": {
                "selected": 40
              },
              "description": "Student counted 40 red items, correct",
              "is_correct": true,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "minis_counting_scene",
                    "params": {
                      "event": "mark_counted",
                      "status": "confirmed",
                      "description": "Red items highlight as counted, count of 40 appears",
                      "category": "Red"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "That's right, 40."
                  },
                  {
                    "type": "current_scene",
                    "elements": [
                      {
                        "tangible_id": "minis_counting_scene",
                        "description": "Minis counting scene. Red items highlighted as counted (40), Blue and Yellow items visible.",
                        "tangible_type": "counting_game",
                        "categories": [
                          "Red",
                          "Blue",
                          "Yellow"
                        ],
                        "counted": [
                          "Red"
                        ]
                      }
                    ]
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 30
              },
              "description": "Student selected 30: undercounted Red items",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "minis_counting_scene",
                    "params": {
                      "event": "highlight_category",
                      "status": "proposed",
                      "description": "Red items pulse to draw attention to full count",
                      "category": "Red"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let's think about this together. Count all the red items the Minis collected. Make sure you count every one."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 50
              },
              "description": "Student selected 50: overcounted Red items",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "minis_counting_scene",
                    "params": {
                      "event": "highlight_category",
                      "status": "proposed",
                      "description": "Red items pulse to draw attention to accurate count",
                      "category": "Red"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Here's a hint: count just the red items carefully. There are fewer than you thought."
                  }
                ]
              ]
            },
            {
              "condition": {
                "selected": 60
              },
              "description": "Student selected 60: confused Red count with Yellow count",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "minis_counting_scene",
                    "params": {
                      "event": "highlight_category",
                      "status": "proposed",
                      "description": "Red items highlight separately from Yellow items",
                      "category": "Red"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "You're working on it. That's the yellow count. Look only at the red items and count those."
                  }
                ]
              ]
            },
            {
              "condition": {},
              "description": "Student answered incorrectly. System models the correct answer.",
              "is_correct": false,
              "steps": [
                [
                  {
                    "type": "scene",
                    "method": "animate",
                    "tangible_id": "minis_counting_scene",
                    "params": {
                      "event": "count_demonstration",
                      "status": "confirmed",
                      "description": "System counts Red items one by one, showing total of 40",
                      "category": "Red"
                    }
                  },
                  {
                    "type": "dialogue",
                    "text": "Let me show you how this works. I count each red item the Minis collected. One, two, three, all the way to 40. The answer is 40."
                  }
                ]
              ]
            }
          ]
        },
        {
          "type": "current_scene",
          "elements": [
            {
              "tangible_id": "minis_counting_scene",
