                "tangible_id": "picture_graph_scale10",
                "description": "Vertical picture graph on right. Scale of 10. Red (4 symbols), Blue (2 symbols), Yellow (6 symbols). Key: Each ⭐ = 10.",
                "tangible_type": "picture_graph",
                "mode": "reading",
