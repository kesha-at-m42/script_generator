    {
      "id": "w3_picture_to_bar_bridge",
      "steps": [
        [
          {
            "type": "scene",
            "method": "hide",
            "tangible_id": "picture_graph_scale5",
            "params": {
              "description": "Scale of 5 picture graph removed from display"
            }
          },
          {
            "type": "scene",
            "method": "add",
            "tangible_id": "bar_graph_scale10",
            "tangible_type": "bar_graph",
            "params": {
              "mode": "reading",
              "orientation": "vertical",
              "scale": 10,
              "categories": [
                "Red",
                "Blue",
                "Yellow"
              ],
              "values": [
                40,
                20,
                60
              ],
              "axis_range": [
                0,
                10,
                20,
                30,
                40,
                50,
                60
              ],
              "description": "Vertical bar graph appears on right. Scale of 10. Axis shows 0, 10, 20, 30, 40, 50, 60. Red bar reaches 40, Blue bar reaches 20, Yellow bar reaches 60."
            }
          },
          {
            "type": "dialogue",
            "text": "Now watch this. Here's the SAME data as a bar graph."
          },
          {
            "type": "dialogue",
            "text": "Red has 40. The picture graph shows 4 symbols. The bar graph shows a bar up to 40. Both graphs show 60 for Yellow. Can you find where?"
          },
          {
            "type": "prompt",
            "text": "Both graphs show 60 for Yellow. Click on where you see 60.",
            "tool": "click_component",
            "target": [
              "picture_graph_scale10.Yellow",
              "bar_graph_scale10.Yellow"
            ],
            "validator": [
              {
                "condition": {},
                "description": "Student clicked either Yellow symbols or Yellow bar, both correct",
                "is_correct": true,
                "steps": [
                  [
                    {
                      "type": "scene",
                      "method": "animate",
                      "tangible_id": "picture_graph_scale10",
                      "params": {
                        "event": "highlight_category",
                        "status": "confirmed",
                        "description": "Yellow symbols highlight on picture graph",
                        "category": "Yellow"
                      }
                    },
                    {
                      "type": "scene",
                      "method": "animate",
                      "tangible_id": "bar_graph_scale10",
                      "params": {
                        "event": "highlight_category",
                        "status": "confirmed",
                        "description": "Yellow bar highlights on bar graph",
                        "category": "Yellow"
                      }
                    },
                    {
                      "type": "dialogue",
                      "text": "Same data! Picture graphs use symbols. Bar graphs use bars. Both show 60."
                    },
                    {
                      "type": "dialogue",
                      "text": "Bar graphs are really useful with scale of 10. You read the HEIGHT instead of counting symbols."
                    },
                    {
                      "type": "current_scene",
                      "elements": [
                        {
                          "tangible_id": "picture_graph_scale10",
                          "description": "Vertical picture graph. Scale of 10. Yellow category highlighted. Red (4 symbols), Blue (2 symbols), Yellow (6 symbols). Key: Each ⭐ = 10.",
                          "tangible_type": "picture_graph",
                          "mode": "reading",
                          "orientation": "vertical",
                          "scale": 10,
                          "categories": [
                            "Red",
                            "Blue",
                            "Yellow"
                          ]
                        },
                        {
                          "tangible_id": "bar_graph_scale10",
                          "description": "Vertical bar graph. Scale of 10. Yellow bar highlighted. Red bar at 40, Blue bar at 20, Yellow bar at 60. Axis: 0, 10, 20, 30, 40, 50, 60.",
                          "tangible_type": "bar_graph",
                          "mode": "reading",
                          "orientation": "vertical",
                          "scale": 10,
                          "categories": [
                            "Red",
                            "Blue",
                            "Yellow"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          {
            "type": "current_scene",
            "elements": [
              {
                "tangible_id": "picture_graph_scale10",
                "description": "Vertical picture graph on left. Scale of 10. Red (4 symbols), Blue (2 symbols), Yellow (6 symbols). Key: Each ⭐ = 10.",
                "tangible_type": "picture_graph",
                "mode": "reading",
