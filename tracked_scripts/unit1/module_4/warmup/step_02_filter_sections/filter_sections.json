    {
      "id": "w2_scale_comparison",
      "steps": [
        [
          {
            "type": "scene",
            "method": "add",
            "tangible_id": "picture_graph_scale5",
            "tangible_type": "picture_graph",
            "params": {
              "mode": "reading",
              "orientation": "vertical",
              "scale": 5,
              "categories": [
                "Red",
                "Blue",
                "Yellow"
              ],
              "values": [
                40,
                20,
                60
              ],
              "description": "Vertical picture graph appears on left. Scale of 5. Red shows 8 symbols (40÷5), Blue shows 4 symbols (20÷5), Yellow shows 12 symbols (60÷5). Key visible: Each ⭐ = 5."
            }
          },
          {
            "type": "scene",
            "method": "add",
            "tangible_id": "picture_graph_scale10",
            "tangible_type": "picture_graph",
            "params": {
              "mode": "reading",
              "orientation": "vertical",
              "scale": 10,
              "categories": [
                "Red",
                "Blue",
                "Yellow"
              ],
              "values": [
                40,
                20,
                60
              ],
              "description": "Vertical picture graph appears on right. Scale of 10. Red shows 4 symbols (40÷10), Blue shows 2 symbols (20÷10), Yellow shows 6 symbols (60÷10). Key visible: Each ⭐ = 10."
            }
          },
          {
            "type": "dialogue",
            "text": "Here's your data two ways. Look at both graphs."
          },
          {
            "type": "prompt",
            "text": "Which graph uses FEWER symbols to show the same data?",
            "tool": "click_tangible",
            "target": [
              "picture_graph_scale5",
              "picture_graph_scale10"
            ],
            "validator": [
              {
                "condition": {
                  "selected": "picture_graph_scale10"
                },
                "description": "Student selected the scale of 10 graph, correct",
                "is_correct": true,
                "steps": [
                  [
                    {
                      "type": "scene",
                      "method": "animate",
                      "tangible_id": "picture_graph_scale10",
                      "params": {
                        "event": "highlight_selection",
                        "status": "confirmed",
                        "description": "Scale of 10 graph highlights to confirm selection"
                      }
                    },
                    {
                      "type": "dialogue",
                      "text": "Scale of 10 uses fewer symbols! Each symbol shows more, so you need fewer of them."
                    },
                    {
                      "type": "dialogue",
                      "text": "With scale of 10, each symbol shows more than scale of 5. That's why you need fewer symbols for the same data!"
                    },
                    {
                      "type": "current_scene",
                      "elements": [
                        {
                          "tangible_id": "picture_graph_scale5",
                          "description": "Vertical picture graph. Scale of 5. Red (8 symbols), Blue (4 symbols), Yellow (12 symbols). Key: Each ⭐ = 5.",
                          "tangible_type": "picture_graph",
                          "mode": "reading",
                          "orientation": "vertical",
                          "scale": 5,
                          "categories": [
                            "Red",
                            "Blue",
                            "Yellow"
                          ]
                        },
                        {
                          "tangible_id": "picture_graph_scale10",
                          "description": "Vertical picture graph highlighted as selected. Scale of 10. Red (4 symbols), Blue (2 symbols), Yellow (6 symbols). Key: Each ⭐ = 10.",
                          "tangible_type": "picture_graph",
                          "mode": "reading",
                          "orientation": "vertical",
                          "scale": 10,
                          "categories": [
                            "Red",
                            "Blue",
                            "Yellow"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          {
            "type": "current_scene",
            "elements": [
              {
                "tangible_id": "picture_graph_scale5",
                "description": "Vertical picture graph on left. Scale of 5. Red (8 symbols), Blue (4 symbols), Yellow (12 symbols). Key: Each ⭐ = 5.",
